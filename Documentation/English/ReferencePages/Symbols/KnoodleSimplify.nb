     RowBox[{"{", 
      RowBox[{"trefC", ",", " ", "hopfC"}], "}"}], ",", " ", 
     RowBox[{"\"\<Unite\>\"", " ", "->", " ", "True"}]}], "]"}], ",", " ", 
   RowBox[{"PlotLegends", " ", "->", " ", "Automatic"}], ",", " ", 
   RowBox[{"ImageSize", " ", "->", " ", "220"}]}], "]"}]], "Input",ExpressionU\
