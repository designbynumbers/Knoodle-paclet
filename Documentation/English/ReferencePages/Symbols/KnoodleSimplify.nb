Cell[BoxData[
 TagBox[
  RowBox[{"Grid", "[", 
   RowBox[{
    RowBox[{"Partition", "[", 
     RowBox[{
      RowBox[{"MapThread", "[", 
       RowBox[{
        RowBox[{
         TemplateBox[{
           RowBox[{"KnoodleDraw", "[", 
