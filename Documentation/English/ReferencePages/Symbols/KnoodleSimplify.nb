Cell["\<\
Simplify a 6-crossing knot; the result is a PlanarDiagramComplex:\
\>", "ExampleText",ExpressionUUID->"98144cbe-17eb-4cb8-ac76-3827f58fd4b2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"pdc", " ", "=", " ", 
  RowBox[{"KnoodleSimplify", "[", 
   RowBox[{"Knot", "[", 
    RowBox[{"6", ",", " ", "2"}], "]"}], "]"}]}]], "Input",ExpressionUUID->\
"f0f666b4-58e4-4bb7-be1c-33bcaa1b33f8"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   TagBox["PlanarDiagramComplex",
    "SummaryHead"], "[", 
   DynamicModuleBox[{Typeset`open$$ = False, Typeset`embedState$$ = "Ready"}, 
    
    TemplateBox[{
      PaneSelectorBox[{False -> GridBox[{{
            GridBox[{{
               RowBox[{
                 TagBox["\"Crossings: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["6", "SummaryItem"]}], ""}, {
               RowBox[{
                 TagBox["\"Summands: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["1", "SummaryItem"]}], 
               RowBox[{
                 TagBox["\"Unknots: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["0", "SummaryItem"]}]}}, 
             GridBoxAlignment -> {
              "Columns" -> {{Left}}, "Rows" -> {{Automatic}}}, AutoDelete -> 
             False, GridBoxItemSize -> {
              "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
             GridBoxSpacings -> {"Columns" -> {{2}}, "Rows" -> {{Automatic}}},
              BaseStyle -> {
              ShowStringCharacters -> False, NumberMarks -> False, 
               PrintPrecision -> 3, ShowSyntaxStyles -> False}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}, "Rows" -> {{Top}}}, 
          AutoDelete -> False, 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
          BaselinePosition -> {1, 1}], True -> GridBox[{{
            GridBox[{{
               RowBox[{
                 TagBox["\"Crossings: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["6", "SummaryItem"]}], ""}, {
               RowBox[{
                 TagBox["\"Summands: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["1", "SummaryItem"]}], 
               RowBox[{
                 TagBox["\"Unknots: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["0", "SummaryItem"]}]}}, 
             GridBoxAlignment -> {
              "Columns" -> {{Left}}, "Rows" -> {{Automatic}}}, AutoDelete -> 
             False, GridBoxItemSize -> {
              "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
             GridBoxSpacings -> {"Columns" -> {{2}}, "Rows" -> {{Automatic}}},
              BaseStyle -> {
              ShowStringCharacters -> False, NumberMarks -> False, 
               PrintPrecision -> 3, ShowSyntaxStyles -> False}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}, "Rows" -> {{Top}}}, 
          AutoDelete -> False, 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
          BaselinePosition -> {1, 1}]}, 
       Dynamic[Typeset`open$$], ImageSize -> Automatic]},
     "SummaryPanel"],
    DynamicModuleValues:>{}], "]"}],
  Knoodle`PlanarDiagramComplex[<|
   "serialized" -> 
    "s 1\n11\t8\t0\t9\t-1\t0\t0\n5\t0\t6\t1\t-1\t0\t0\n1\t6\t2\t7\t-1\t0\t0\n\
7\t2\t8\t3\t-1\t0\t0\n3\t11\t4\t10\t1\t0\t0\n9\t5\t10\t4\t1\t0\t0\n"|>],
  Editable->False,
  SelectWithContents->True,
  Selectable->False]], "Output",ExpressionUUID->"dea84cc2-4ce2-4a14-94ab-\
b0fbbea0b4f8"]
}, Open  ]],

Cell["The result can be drawn and identified directly:", "ExampleText",ExpressionUUID->"305ded6a-f974-4017-b1ba-0662a60cefbd"],

