Cell["", "ExampleDelimiter",ExpressionUUID->"a7f9a0a3-ca88-4290-b8b7-810802eaf00e"],

Cell["\<\
Simplification decomposes a composite knot into its connect-sum factors. \
Generate a Gaussian random polygon with 5000 vertices and simplify it:\
\>", "ExampleText",ExpressionUUID->"f0eee07c-865c-4a6e-9513-f3927263b496"],

Cell[BoxData[
 RowBox[{
  RowBox[{"GaussianRandomPolygon", "[", "n_", "]"}], " ", ":=", " ", 
  RowBox[{"Accumulate", "[", 
   RowBox[{"Standardize", "[", 
    RowBox[{
     RowBox[{"RandomVariate", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"n", ",", " ", "3"}], "}"}]}], "]"}], ",", " ", "Mean", ",", 
     " ", 
     RowBox[{"1", " ", "&"}]}], " ", "]"}], "]"}]}]], "Input",ExpressionUUID->\
"c037f046-e56a-4def-af2c-d7ff4a6ad040"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SeedRandom", "[", "1", "]"}], ";", " ", 
   RowBox[{"P", " ", "=", " ", 
    RowBox[{"GaussianRandomPolygon", "[", "5000", "]"}]}], ";"}], 
  " "}]], "Input",ExpressionUUID->"b7d6fd5b-53fe-4ee0-82e4-2ec13818fea0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"split", " ", "=", " ", 
  RowBox[{"KnoodleSimplify", "[", "P", "]"}]}]], "Input",ExpressionUUID->\
"c7990351-8310-464d-ac24-a3201391683d"],

