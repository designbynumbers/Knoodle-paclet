Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"68637a83-9135-45d2-a7c0-644b9541433a"],

Cell["\<\
T. Applebaum, S. Blackwell, A. Davies, T. Edlich, A. Juh\[AAcute]sz, M. \
Lackenby, N. Toma\[SHacek]ev and D. Zheng, \"The Unknotting Number, Hard \
Unknot Diagrams, and Reinforcement Learning\", Experimental Mathematics, 2025 \
(arXiv:2409.09032) used reinforcement learning to construct unknot diagrams \
designed to be hard to simplify. The three largest of the paper's published \
examples (59, 51, and 48 crossings) ship with this paclet:\
\>", "ExampleText",ExpressionUUID->"547911bc-2086-4c0a-bd29-71a3de021d7d"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"vdir", "=", 
    RowBox[{
     RowBox[{"PacletObject", "[", "\"\<Knoodle\>\"", "]"}], "[", 
     RowBox[{"\"\<AssetLocation\>\"", ",", "\"\<VeryHardUnknots\>\""}], 
     "]"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"74eaaf7a-3048-4714-8ad3-3359bb5baa11"],

