Cell["", "ExampleDelimiter",ExpressionUUID->"94a601de-fdc2-4b89-82dc-57517bb5834b"],

Cell["\<\
Generate a Gaussian random 1000-gon, simplify it to a knot diagram, and draw \
the result:\
\>", "ExampleText",ExpressionUUID->"f01a90a8-15d8-4f28-980a-0bcc4f3a92ba"],

Cell[BoxData[
 RowBox[{
  RowBox[{"GaussianRandomPolygon", "[", "n_", "]"}], ":=", 
  RowBox[{"Accumulate", "[", 
   RowBox[{"Standardize", "[", 
    RowBox[{
     RowBox[{"RandomVariate", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "3"}], "}"}]}], "]"}], ",", "Mean", ",", 
     RowBox[{"1", "&"}]}], "]"}], "]"}]}]], "Input",ExpressionUUID->"92ae5ee1-\
5ebb-4b08-9660-c89e41d361de"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "4", "]"}], ";", 
  RowBox[{"P", "=", 
   RowBox[{"GaussianRandomPolygon", "[", "1000", "]"}]}], ";"}]], "Input",Expr\
essionUUID->"dc356c16-b797-46ad-b88f-a7137d603868"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"pdc", "=", 
