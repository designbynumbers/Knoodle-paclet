Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"7c302e9c-5bbd-4a12-b200-09d409f89a1b"],

Cell["\<\
\"SimplifyLevel\" controls how hard KnoodleSimplify works. Levels 1-3 are \
local-only diagnostic tiers: 1 removes Reidemeister I kinks, 2 uses \
Reidemeister I and II, 3 all local moves. Level 4 switches to path rerouting, \
5 adds connect-sum detection, and the default (Automatic, or 6 and up) is the \
full Reapr pipeline. Each tier bites deeper into the 128-crossing raw \
projection of a Gaussian random 100-gon:\
\>", "ExampleText",ExpressionUUID->"066b6b00-0f96-4563-8fcf-7ac558dca07e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SeedRandom", "[", "5", "]"}], ";", " ", 
   RowBox[{"Q", " ", "=", " ", 
    RowBox[{"GaussianRandomPolygon", "[", "100", "]"}]}], ";"}], 
  " "}]], "Input",ExpressionUUID->"754bb956-0202-411f-9917-e8535c3bfdb6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"stages", " ", "=", " ", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"KnoodleSimplify", "[", 
      RowBox[{"Q", ",", " ", 
       RowBox[{"\"\<SimplifyLevel\>\"", " ", "->", " ", "#1"}], ",", " ", 
       RowBox[{"\"\<RandomizeProjection\>\"", " ", "->", " ", "False"}]}], 
      "]"}], " ", "&"}], " ", ")"}], " ", "/@", " ", 
   RowBox[{"{", 
    RowBox[{
    "0", ",", " ", "1", ",", " ", "2", ",", " ", "3", ",", " ", "Automatic"}],
     "}"}]}]}]], "Input",ExpressionUUID->"e51968f0-897f-4395-ad03-\
a27f8762bf63"],

