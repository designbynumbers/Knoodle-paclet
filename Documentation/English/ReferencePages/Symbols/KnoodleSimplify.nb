Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"2104e8bd-9f58-4d45-af9c-f3f1df7dae60"],

Cell["\<\
\"SimplifyLevel\" controls how hard KnoodleSimplify works: level 3 uses \
Reidemeister I+II moves only, level 4 adds path rerouting, level 5 adds \
summand detection, and the default is the full Reapr pipeline. Haken's \
141-crossing Gordian unknot is completely rigid under everything below the \
full pipeline:\
\>", "ExampleText",ExpressionUUID->"365a17e9-ca76-417d-b714-b0da7126fe87"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"haken", "=", 
    RowBox[{"Last", "[", "hardunknots", "]"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"999ad439-1179-4577-bd0c-2f00c05274f1"],

Cell[CellGroupData[{

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"KnoodleSimplify", "[", 
      RowBox[{"haken", ",", 
       RowBox[{"\"\<SimplifyLevel\>\"", "\[Rule]", "#1"}]}], "]"}], "&"}], 
    ")"}], "/@", 
   RowBox[{"{", 
    RowBox[{"3", ",", "4", ",", "5"}], "}"}]}],
