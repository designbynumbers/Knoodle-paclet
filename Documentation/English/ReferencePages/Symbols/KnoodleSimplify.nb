Cell["", "ExampleDelimiter",ExpressionUUID->"85ebec82-c6d3-4150-afac-b176d4b21f8b"],

Cell["\<\
Simplification decomposes a composite knot into its connect-sum factors. \
Generate a Gaussian random polygon with 5000 vertices and simplify it:\
\>", "ExampleText",ExpressionUUID->"67de0571-f5c8-4aa3-9397-90891a62e59d"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"GaussianRandomPolygon", "[", "n_", "]"}], ":=", 
   RowBox[{"Accumulate", "[", 
    RowBox[{"Standardize", "[", 
     RowBox[{
      RowBox[{"RandomVariate", "[", 
       RowBox[{
        RowBox[{"NormalDistribution", "[", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "3"}], "}"}]}], "]"}], ",", "Mean", ",", 
      RowBox[{"1", "&"}]}], "]"}], "]"}]}],
  HoldForm]], "Input",ExpressionUUID->"b89e8a97-9a92-48d7-9614-67dac7907e0a"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"SeedRandom", "[", "1", "]"}], ";", 
   RowBox[{"P", "=", 
    RowBox[{"GaussianRandomPolygon", "[", "5000", "]"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"31fbcbd3-35d9-408f-9311-29f8c842097f"],

Cell[CellGroupData[{

Cell[BoxData[
 TagBox[
  RowBox[{"split", "=", 
   RowBox[{"KnoodleSimplify", "[", "P", "]"}]}],
  HoldForm]], "Input",ExpressionUUID->"d0f59d9a-1457-403c-b2c7-b69c98bb2f0b"],

