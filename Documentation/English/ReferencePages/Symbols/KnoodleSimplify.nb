Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"a81a8604-620e-4733-bc46-0cf912037ee7"],

Cell["\<\
To compute invariants with the KnotTheory` package, request the result as \
KnotTheory PD codes: \"OutputFormat\" -> \"KnotTheory\" returns one \
PD[X[...], ...] per physically split portion of the link (a bare PD code when \
there is only one). PD codes cannot express that separate diagrams share a \
link component, so this implies \"Unite\" -> True. This 200-vertex Gaussian \
random polygon is a composite knot (a trefoil connect-summed with a 5_2); it \
simplifies straight to a single 8-crossing PD code, the factors united:\
\>", "ExampleText",ExpressionUUID->"cead688d-1579-4359-91b2-200b01de4afa"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<KnotTheory`\>\"", "]"}]], "Input",ExpressionUUID->"5d702de1-8c18-460c-b0f7-d6db16d5c36f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SeedRandom", "[", "5", "]"}], ";", " ", 
   RowBox[{"R", " ", "=", " ", 
    RowBox[{"GaussianRandomPolygon", "[", "200", "]"}]}], ";"}], 
  " "}]], "Input",ExpressionUUID->"2b6b428f-7f58-4c01-bb05-727a471455e5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"pdR", " ", "=", " ", 
  RowBox[{"KnoodleSimplify", "[", 
   RowBox[{"R", ",", " ", 
    RowBox[{"\"\<OutputFormat\>\"", " ", "->", " ", "\"\<KnotTheory\>\""}], ",",
     " ", 
    RowBox[{"\"\<RandomizeProjection\>\"", " ", "->", " ", "False"}]}], 
   "]"}]}]], "Input",ExpressionUUID->"3c92c190-85e9-4738-a0fa-ab2c81aec228"],

Cell[BoxData[
 RowBox[{"PD", "[", 
  RowBox[{
   RowBox[{"X", "[", 
    RowBox[{"13", ",", "1", ",", "14", ",", "16"}], "]"}], ",", 
   RowBox[{"X", "[", 
    RowBox[{"1", ",", "4", ",", "2", ",", "5"}], "]"}], ",", 
   RowBox[{"X", "[", 
    RowBox[{"5", ",", "2", ",", "6", ",", "3"}], "]"}], ",", 
   RowBox[{"X", "[", 
    RowBox[{"3", ",", "6", ",", "4", ",", "7"}], "]"}], ",", 
   RowBox[{"X", "[", 
    RowBox[{"7", ",", "13", ",", "8", ",", "12"}], "]"}], ",", 
   RowBox[{"X", "[", 
    RowBox[{"11", ",", "9", ",", "12", ",", "8"}], "]"}], ",", 
   RowBox[{"X", "[", 
    RowBox[{"9", ",", "15", ",", "10", ",", "14"}], "]"}], ",", 
   RowBox[{"X", "[", 
    RowBox[{"15", ",", "11", ",", "16", ",", "10"}], "]"}]}], "]"}]], "Output",\
ExpressionUUID->"e28a3dac-a6c1-4c17-b6a9-4570a845e083"]
}, Open  ]],

Cell["\<\
The result feeds KnotTheory's invariant machinery directly -- here its Jones \
polynomial:\
\>", "ExampleText",ExpressionUUID->"d7e26ba9-88f9-4886-b095-889d9a6b22de"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Jones", "[", "pdR", "]"}], "[", "q", "]"}]], "Input",ExpressionUUID\
->"c733925a-250a-4770-8c75-2cf28432f0c2"],

Cell[BoxData[
 RowBox[{"-", 
  FractionBox[
   RowBox[{
    SqrtBox["q"], " ", 
    RowBox[{"X", "[", 
     RowBox[{"13", ",", "1", ",", "14", ",", "16"}], "]"}]}], 
   RowBox[{"1", "+", "q"}]]}]], "Output",ExpressionUUID->"45be5134-e3bb-4ee9-\
9bb7-c8054f4ea296"]
}, Open  ]],

Cell["\<\
The trefoil-with-Hopf-link connect sum from the previous example unites into \
a single two-component code, and KnotTheory computes link invariants from it \
just as directly:\
\>", "ExampleText",ExpressionUUID->"54357c36-65a8-425b-86fd-80bc69074052"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"pdTH", " ", "=", " ", 
  RowBox[{"KnoodleSimplify", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"trefC", ",", " ", "hopfC"}], "}"}], ",", " ", 
    RowBox[{"\"\<OutputFormat\>\"", " ", "->", " ", "\"\<KnotTheory\>\""}]}], 
   "]"}]}]], "Input",ExpressionUUID->"4e289927-068f-4418-9fe9-db4eacf8fd9b"],

Cell[BoxData[
 RowBox[{"PD", "[", 
  RowBox[{
   RowBox[{"X", "[", 
    RowBox[{"5", ",", "8", ",", "6", ",", "1"}], "]"}], ",", 
   RowBox[{"X", "[", 
    RowBox[{"1", ",", "10", ",", "2", ",", "9"}], "]"}], ",", 
   RowBox[{"X", "[", 
    RowBox[{"9", ",", "2", ",", "10", ",", "3"}], "]"}], ",", 
   RowBox[{"X", "[", 
    RowBox[{"3", ",", "6", ",", "4", ",", "7"}], "]"}], ",", 
   RowBox[{"X", "[", 
    RowBox[{"7", ",", "4", ",", "8", ",", "5"}], "]"}]}], "]"}]], "Output",Exp\
ressionUUID->"9adc4b8e-c533-4571-ae26-f5404c1d243d"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Jones", "[", "pdTH", "]"}], "[", "q", "]"}]], "Input",ExpressionUUI\
D->"1e336ffb-ecc6-4aae-969e-c8dc96c7321a"],

Cell[BoxData[
 RowBox[{"-", 
  FractionBox[
   RowBox[{
    SqrtBox["q"], " ", 
    RowBox[{"X", "[", 
     RowBox[{"5", ",", "8", ",", "6", ",", "1"}], "]"}]}], 
   RowBox[{"1", "+", "q"}]]}]], "Output",ExpressionUUID->"d760a426-ba81-4440-\
8f0d-31dc4c3f4b33"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"e8e5a1bc-df74-4af7-90a7-02bcc4e838cd"],

Cell["\<\
A list of point lists is a multi-component link, one closed 3D curve per \
component. Superimpose two Gaussian random 20-gons, the second nudged half a \
unit sideways (each polygon's steps sum to zero, so its last vertex is \
exactly the origin -- unshifted copies would touch there). With this seed the \
two polygons happen to link:\
\>", "ExampleText",ExpressionUUID->"9206174b-db03-4f2c-8751-fd2a0bb753b2"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SeedRandom", "[", "3", "]"}], ";", " ", 
   RowBox[{"L1", " ", "=", " ", 
    RowBox[{"GaussianRandomPolygon", "[", "20", "]"}]}], ";"}], 
  " "}]], "Input",ExpressionUUID->"96303709-3183-4bd5-b2c9-cec080b6cd98"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"L2", " ", "=", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"#1", " ", "+", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"1", "/", "2"}], ",", " ", "0", ",", " ", "0"}], "}"}]}], 
       " ", "&"}], " ", ")"}], " ", "/@", " ", 
     RowBox[{"GaussianRandomPolygon", "[", "20", "]"}]}]}], ";"}], 
  " "}]], "Input",ExpressionUUID->"d23618a4-1e5b-4828-88dd-b3479f899c5f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"hopf", " ", "=", " ", 
  RowBox[{"KnoodleSimplify", "[", 
   RowBox[{"{", 
    RowBox[{"L1", ",", " ", "L2"}], "}"}], "]"}]}]], "Input",ExpressionUUID->\
"3db30f0e-52fc-4a71-ba69-8b370f55dfe3"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   TagBox["PlanarDiagramComplex",
    "SummaryHead"], "[", 
