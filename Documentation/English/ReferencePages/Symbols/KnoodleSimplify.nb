Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"11129a1d-0959-4caa-8d2f-f4557f5b232d"],

Cell["\<\
Colors carry link-component identity through a complex. Here a composite link \
-- the connect sum of a trefoil and a Hopf link -- as native colored PD \
input: the last two columns of each crossing row are the incoming under- and \
over-arcs' component colors, so the trefoil rows live on component 0 while \
the Hopf rows carry components 0 and 1:\
\>", "ExampleText",ExpressionUUID->"f0070fcf-402b-446e-b9ba-b0a21b6ccb88"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"trefC", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "0", ",", " ", "3", ",", " ", "1", ",", " ", "4", ",", " ", "0", ",", 
        " ", "0"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
       "2", ",", " ", "5", ",", " ", "3", ",", " ", "0", ",", " ", "0", ",", 
        " ", "0"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
       "4", ",", " ", "1", ",", " ", "5", ",", " ", "2", ",", " ", "0", ",", 
        " ", "0"}], "}"}]}], "}"}]}], ";"}], " "}]], "Input",ExpressionUUID->\
"af30315f-5fd4-4be7-8181-c4c8703d17e1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"hopfC", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "3", ",", " ", "0", ",", " ", "2", ",", " ", "1", ",", " ", "1", ",", 
        " ", "0"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
       "1", ",", " ", "2", ",", " ", "0", ",", " ", "3", ",", " ", "0", ",", 
        " ", "1"}], "}"}]}], "}"}]}], ";"}], " "}]], "Input",ExpressionUUID->\
"2e1bf91e-b2c4-48d5-9b25-e84fb9eeaca9"],

Cell["\<\
\"Unite\" -> True splices same-colored factors together: the whole link is \
one connected 5-crossing diagram with two components:\
\>", "ExampleText",ExpressionUUID->"bd4af8bd-10b6-4ac6-ba11-959eac75f3c1"],

