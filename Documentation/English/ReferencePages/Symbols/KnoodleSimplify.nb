Cell[CellGroupData[{

Cell["KnoodleSimplify", "ObjectName",ExpressionUUID->"ce76e741-3e60-4cd6-b3c5-e9448e306892"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"7cf44904-2526-43df-b9a9-404d3ad3ab3e"],
 Cell[BoxData[
  RowBox[{"KnoodleSimplify", "[", 
   StyleBox["input", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "792813a2-946e-41a6-b482-0419029d6f2a"],
 "\[LineSeparator]simplifies a knot or link diagram, reducing the number of \
crossings without changing the underlying knot or link type."
}], "Usage",ExpressionUUID->"8b141695-ce8d-4cfb-8c5b-870695c8a589"],

Cell["\<\
Returns a PlanarDiagramComplex object representing the simplified diagram, \
which can be passed directly to KnoodleDraw (to see the picture) or \
KnoodleIdentify (to look it up in the knot table). input accepts the same \
representations as KnoodleDraw.\
\>", "Notes",ExpressionUUID->"3afafcdd-2a47-4c71-bb46-cada8f7a39d6"],

Cell["\<\
A composite diagram is decomposed into its connect-sum factors: by default \
the result holds one diagram per diagrammatically-prime factor (factors of \
the same link component share a color), the natural input for \
KnoodleIdentify. \"Unite\" -> True connect-sums same-colored factors back \
together, giving one diagram per split component -- the natural \
one-PD-per-component form for other software.\
\>", "Notes",ExpressionUUID->"861ee114-d51d-4ba0-a01e-d6f799627224"],

Cell["\<\
A diagram that simplifies all the way to a 0-crossing unknot is recorded as \
an unknot summand of the complex rather than disappearing.\
\>", "Notes",ExpressionUUID->"12438687-329c-4d43-b5a0-d48e697d5096"],

Cell["The following options can be given:", "Notes",ExpressionUUID->"27f7be5e-933d-4749-b61b-50b8870c905e"],

Cell[BoxData[GridBox[{
   {Cell["      ", "ModInfo",ExpressionUUID->
     "f3a18ae6-7bff-4dba-b3eb-67961039be80"], "\"\<SimplifyLevel\>\"", 
    "Automatic", Cell["\<\
simplification effort: 0 none; 1, 2, 3 are local-only tiers (Reidemeister I; \
I+II; all local moves); 4 path rerouting; 5 adds summand detection; Automatic \
(or 6 and up) is the full Reapr pipeline\
\>", "TableText",ExpressionUUID->"72b4401e-d65d-4e28-997b-5848dbff4eb3"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "e39d084f-3d2f-4b3e-8c7d-2522807bf033"], "\"\<Unite\>\"", "False", 
    Cell["\<\
False: one diagram per prime connect-sum factor; True: reconnect same-colored \
factors into one diagram per split component\
\>", "TableText",ExpressionUUID->"1b645d38-84c1-4306-9286-7750e610ed52"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "7c8dc6bd-7cb8-4307-89c5-921640269782"], "\"\<RandomizeProjection\>\"", 
    "True", Cell["\<\
randomly rotate 3D input before projecting, avoiding degenerate projections; \
set False for reproducibility\
\>", "TableText",ExpressionUUID->"845e7cad-28e1-465d-be3d-cea33831b33b"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "e41ba088-b105-4a6a-a888-fbe30ad481b5"], "\"\<MaxReaprAttempts\>\"", 
    "Automatic", Cell["\<\
maximum number of Reapr iterations; Automatic is the tool's default of 25. \
Reapr runs only at \"SimplifyLevel\" 6 and up, so this has no effect at lower \
levels\
\>", "TableText",ExpressionUUID->"9ef8dcef-6922-4a5c-bf81-0f2326000085"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "a8e9f2e0-ac8f-4d1e-abf8-72e5ca191046"], "\"\<Compaction\>\"", "True", 
    Cell["\<\
whether the Reapr layout runs OrthoDraw's compaction pass; False skips it \
(Reapr only)\
\>", "TableText",ExpressionUUID->"03bf3a52-04c4-4bef-b0c0-1f5ab7ac0cd6"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "0a24c57b-5175-4b95-897a-bb21356af7e1"], "\"\<ReaprEnergy\>\"", 
    "Automatic", Cell["\<\
energy functional Reapr minimizes: Automatic (the tool's default), or one of \
\"TV\", \"Height\", \"TV_MCF\" (Reapr only)\
\>", "TableText",ExpressionUUID->"164f4c18-799b-426c-ac0a-e4c05854925a"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "60ae6587-342c-4284-b2de-18e1434239be"], "\"\<SimplifyOptions\>\"", 
    RowBox[{"{", "}"}], Cell["\<\
extra knoodlesimplify flags, e.g. {\"dijkstra-strategy\" -> \"alternating\"}; \
see knoodlesimplify --help\
\>", "TableText",ExpressionUUID->"3c46d304-a450-4aae-a13f-c83ff7522001"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "9f114ca3-9d8c-42da-9187-12bad969b3bc"], "\"\<OutputFormat\>\"", \
"\"\<PlanarDiagramComplex\>\"", Cell["\<\
\"KnotTheory\" returns KnotTheory` PD codes instead: one PD[X[...], ...] per \
physically split portion of the link (a list when there are several; \
PD[Loop[1]] for a 0-crossing portion). Implies \"Unite\" -> True\
\>", "TableText",ExpressionUUID->"af7c7e34-43e2-4509-8465-bc088daeb2b8"]}
  }]], "3ColumnTableMod",ExpressionUUID->"6fb53a36-292e-4974-af40-\
f0cb362e110d"]
}, Open  ]],

