Notebook[{

Cell[CellGroupData[{
Cell["Categorization", "CategorizationSection",ExpressionUUID->"80ac71f0-7ad8-419b-adf7-7155ffc70bc0"],

Cell["Symbol", "Categorization",
 CellLabel->
  "Entity Type",ExpressionUUID->"b47918cc-4925-4cfb-bd97-139f5d3b5f42"],

Cell["Knoodle", "Categorization",
 CellLabel->
  "Paclet Name",ExpressionUUID->"d7cf7435-d159-4ff9-bda0-086029fc8512"],

Cell["Knoodle`", "Categorization",
 CellLabel->"Context",ExpressionUUID->"5d0390c7-8cb3-4a7d-b05c-127516cfc1c4"],

Cell["Knoodle/ref/KnotSymbol", "Categorization",
 CellLabel->"URI",ExpressionUUID->"eb25c119-c73b-4412-b8b5-22dcdf67f14c"]
}, Closed]],

Cell[CellGroupData[{

Cell["KnotSymbol", "ObjectName",ExpressionUUID->"3b3448ab-3804-4086-958b-943a2dd8586b"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"74ba00df-54fe-43c5-9ed6-a14e6d0860ae"],
 Cell[BoxData[
  RowBox[{"KnotSymbol", "[", 
   RowBox[{
    StyleBox["c", "TI"], ",", 
    StyleBox["i", "TI"], ",", 
    StyleBox["alternating", "TI"], ",", 
    StyleBox["coset", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "6c79bf83-89d0-4393-8ee7-d87cb8da103d"],
 "\[LineSeparator]represents a prime knot identified by KnoodleIdentify, in \
KnotInfo naming."
}], "Usage",ExpressionUUID->"81c16fab-20f9-4a50-ae5d-624d7fbb298b"],

Cell["\<\
KnotSymbol expressions appear as the keys of the Association that \
KnoodleIdentify returns. c is the knot's minimal crossing number and i its \
index within KnotInfo's per-crossing-number naming scheme (the 2 in 5_2); \
alternating is True or False per KnotInfo's classification; coset names which \
coset of the symmetry group {e, m, r, mr} the identified diagram represents \
(e = identity, m = mirror, r = reverse, mr = both), with '/'-joined values \
when several variants are topologically the same knot, e.g. \"e/r\" or \"m/mr\
\".\
\>", "Notes",ExpressionUUID->"40761f6a-d7fb-4524-9fb8-fcfeed76535c"],

Cell["\<\
Each knot has one KnotInfo symmetry type, which determines its possible coset \
values: chiral (\"e\", \"r\", \"m\", \"mr\"), reversible (\"e/r\", \"m/mr\"), \
negative amphichiral (\"e/mr\", \"m/r\"), positive amphichiral (\"e/m\", \
\"r/mr\"), or fully amphichiral (\"e/m/r/mr\").\
\>", "Notes",ExpressionUUID->"f6eb5577-d846-44d3-91a0-4a845a3ba3f2"],

Cell["\<\
KnotSymbol displays in ordinary KnotInfo notation: c with subscript i for \
knots up to 10 crossings, and c immediately followed by \"a\" (alternating) \
or \"n\" (non-alternating) with subscript i from 11 crossings up. The coset \
appears as a superscript, except that a coset containing e is the unmodified \
variant and displays without one.\
\>", "Notes",ExpressionUUID->"86dd9169-f850-4ca6-a1c8-563a27207620"],

Cell["\<\
The display is formatting only: the FullForm, pattern matching, and equality \
testing of a KnotSymbol expression are unaffected, and its parts can be \
extracted positionally.\
\>", "Notes",ExpressionUUID->"ef350a66-2de1-4ca0-a92e-f2a3a2bafa7e"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[GridBox[{
    {
     StyleBox["Examples", "PrimaryExamplesSection"], ""}
   }],
  $Line = 0; Null]], "PrimaryExamplesSection",ExpressionUUID->"fae83a45-3975-\
4913-b87d-11def507a13a"],

Cell[BoxData[
 TagBox[
  RowBox[{"Needs", "[", "\"\<Knoodle`\>\"", "]"}],
  HoldForm]], "Input",ExpressionUUID->"9d8fa1d3-ada3-45f1-87bb-65d51b33d165"],

Cell["\<\
KnoodleIdentify returns KnotSymbol keys; Knot[3,1] identifies as the \
mirror-trefoil coset:\
\>", "ExampleText",ExpressionUUID->"b7af9fd8-6255-4a23-8f5e-b83e3d02e788"],

Cell[CellGroupData[{

Cell[BoxData[
 TagBox[
  RowBox[{"KnoodleIdentify", "[", 
   RowBox[{"Knot", "[", 
    RowBox[{"3", ",", "1"}], "]"}], "]"}],
  HoldForm]], "Input",ExpressionUUID->"1b19532b-6156-4368-8997-8a3cb605476d"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   InterpretationBox[
    TemplateBox[{
      SubscriptBox["3", "1"], "\"m/mr\""},
     "Superscript"],
    Knoodle`KnotSymbol[3, 1, True, "m/mr"]], "\[Rule]", "1"}], 
  "\[RightAssociation]"}]], "Output",ExpressionUUID->"8674629a-14d5-454d-8a00-\
0aaffd67ee43"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"19c886dc-5007-4d00-9e2b-7de1448c95e2"],

Cell["\<\
KnotInfo display notation: the coset superscript is suppressed when the coset \
contains e, and knots of 11 or more crossings carry an \
alternating/non-alternating tag:\
\>", "ExampleText",ExpressionUUID->"bd60ff78-1294-4b53-9c91-ced292498881"],

Cell[CellGroupData[{

Cell[BoxData[
 TagBox[
  RowBox[{"{", 
   RowBox[{
    InterpretationBox[
     SubscriptBox["3", "1"],
     Knoodle`KnotSymbol[3, 1, True, "e/r"]], ",", 
    InterpretationBox[
     TemplateBox[{
       SubscriptBox["3", "1"], "\"m/mr\""},
      "Superscript"],
     Knoodle`KnotSymbol[3, 1, True, "m/mr"]], ",", 
    InterpretationBox[
     SubscriptBox["\"\<11a\>\"", "456"],
     Knoodle`KnotSymbol[11, 456, True, "e/r"]], ",", 
    InterpretationBox[
     TemplateBox[{
       SubscriptBox["\"12n\"", "3541"], "\"m\""},
      "Superscript"],
     Knoodle`KnotSymbol[12, 3541, False, "m"]]}], "}"}],
  HoldForm]], "Input",ExpressionUUID->"4344de8a-42c6-4535-aab2-5433214d4226"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   InterpretationBox[
    SubscriptBox["3", "1"],
    Knoodle`KnotSymbol[3, 1, True, "e/r"]], ",", 
   InterpretationBox[
    TemplateBox[{
      SubscriptBox["3", "1"], "\"m/mr\""},
     "Superscript"],
    Knoodle`KnotSymbol[3, 1, True, "m/mr"]], ",", 
   InterpretationBox[
    SubscriptBox["\<\"11a\"\>", "456"],
    Knoodle`KnotSymbol[11, 456, True, "e/r"]], ",", 
   InterpretationBox[
    TemplateBox[{
      SubscriptBox["\"12n\"", "3541"], "\"m\""},
     "Superscript"],
    Knoodle`KnotSymbol[12, 3541, False, "m"]]}], "}"}]], "Output",ExpressionUU\
ID->"a18e52dc-4cf2-437d-bc5a-06a321d07749"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"79a90975-d0c8-4e1f-ae6b-df1b839e8667"],

Cell["\<\
The display is formatting only; the underlying expression is unchanged:\
\>", "ExampleText",ExpressionUUID->"0e795aae-3155-46a9-89ca-f6d0a05cc9fe"],

Cell[CellGroupData[{

Cell[BoxData[
 TagBox[
  TagBox[
   StyleBox[
    RowBox[{"KnotSymbol", "[", 
     RowBox[{"3", ",", "1", ",", "True", ",", "\"\<m/mr\>\""}], "]"}],
    ShowSpecialCharacters->False,
    ShowStringCharacters->True,
    NumberMarks->True],
   FullForm],
  HoldForm]], "Input",ExpressionUUID->"8f2f4be1-67d6-40ce-a566-dc66ab8b6f8c"],

Cell[BoxData[
 TagBox[
  StyleBox[
   RowBox[{"KnotSymbol", "[", 
    RowBox[{"3", ",", "1", ",", "True", ",", "\"\<m/mr\>\""}], "]"}],
   ShowSpecialCharacters->False,
   ShowStringCharacters->True,
   NumberMarks->True],
  FullForm]], "Output",ExpressionUUID->"51d8346b-5da5-461d-a507-45dccbbdd3a9"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"dd09b7a9-9013-48c7-bfba-509775a11a7f"],

Cell["\<\
Extract the crossing number of an identified knot positionally:\
\>", "ExampleText",ExpressionUUID->"239b803f-1b53-4580-902b-49559e5cd540"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"ks", "=", 
    RowBox[{"First", "[", 
     RowBox[{"Keys", "[", 
      RowBox[{"KnoodleIdentify", "[", 
       RowBox[{"Knot", "[", 
        RowBox[{"7", ",", "4"}], "]"}], "]"}], "]"}], "]"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"7a872928-ddaf-4115-bb96-8f99bea2153c"],

Cell[CellGroupData[{

Cell[BoxData[
 TagBox[
  RowBox[{"ks", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}],
  HoldForm]], "Input",ExpressionUUID->"0b7a99cb-58dd-4e09-bba4-6a867b172558"],

Cell[BoxData["7"], "Output",ExpressionUUID->"9ffd7ca2-1d56-4c52-843e-18e02d40138a"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
},
