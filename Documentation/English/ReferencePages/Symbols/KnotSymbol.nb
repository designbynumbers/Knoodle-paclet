Notebook[{

Cell[CellGroupData[{
Cell["Categorization", "CategorizationSection",ExpressionUUID->"c227caae-76c1-4e0a-a2bc-d116727f2dbe"],

Cell["Symbol", "Categorization",
 CellLabel->
  "Entity Type",ExpressionUUID->"3ec16b10-ec03-438e-a1f3-c3f5fd03e0d5"],

Cell["Knoodle", "Categorization",
 CellLabel->
  "Paclet Name",ExpressionUUID->"1ddc650c-bed5-4cdc-a635-f9d8c5a708f3"],

Cell["Knoodle`", "Categorization",
 CellLabel->"Context",ExpressionUUID->"777ea385-e19f-4d35-8d7f-fcb9aef7d51f"],

Cell["Knoodle/ref/KnotSymbol", "Categorization",
 CellLabel->"URI",ExpressionUUID->"18eed592-4809-43f5-aaca-a4d1c257fd0a"]
}, Closed]],

Cell[CellGroupData[{

Cell["KnotSymbol", "ObjectName",ExpressionUUID->"f6161eb5-b02c-4904-aaf6-47287b884592"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"ee16b250-52a1-49b7-87e9-7721630adbcb"],
 Cell[BoxData[
  RowBox[{"KnotSymbol", "[", 
   RowBox[{
    StyleBox["c", "TI"], ",", 
    StyleBox["i", "TI"], ",", 
    StyleBox["alternating", "TI"], ",", 
    StyleBox["coset", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "e87298bd-4ca6-412a-be5b-27f4a8868302"],
 "\[LineSeparator]represents a prime knot identified by KnoodleIdentify, in \
KnotInfo naming."
}], "Usage",ExpressionUUID->"027bc56a-c146-454a-b26f-4175bba84a4a"],

Cell["\<\
KnotSymbol expressions appear as the keys of the Association that \
KnoodleIdentify returns. c is the knot's minimal crossing number and i its \
index within KnotInfo's per-crossing-number naming scheme (the 2 in 5_2); \
alternating is True or False per KnotInfo's classification; coset names which \
coset of the symmetry group {e, m, r, mr} the identified diagram represents \
(e = identity, m = mirror, r = reverse, mr = both), with '/'-joined values \
when several variants are topologically the same knot, e.g. \"e/r\" or \"m/mr\
\".\
\>", "Notes",ExpressionUUID->"f5fe7256-1e1f-4bea-82ec-198036bf3e1a"],

Cell["\<\
Each knot has one KnotInfo symmetry type, which determines its possible coset \
values: chiral (\"e\", \"r\", \"m\", \"mr\"), reversible (\"e/r\", \"m/mr\"), \
negative amphichiral (\"e/mr\", \"m/r\"), positive amphichiral (\"e/m\", \
\"r/mr\"), or fully amphichiral (\"e/m/r/mr\").\
\>", "Notes",ExpressionUUID->"4a7b8176-55db-4583-bc24-8881a265e08c"],

Cell["\<\
KnotSymbol displays in ordinary KnotInfo notation: c with subscript i for \
knots up to 10 crossings, and c immediately followed by \"a\" (alternating) \
or \"n\" (non-alternating) with subscript i from 11 crossings up. The coset \
appears as a superscript, except that a coset containing e is the unmodified \
variant and displays without one.\
\>", "Notes",ExpressionUUID->"09342db6-d8b6-4be9-bc3a-1f5725171dbf"],

Cell["\<\
The display is formatting only: the FullForm, pattern matching, and equality \
testing of a KnotSymbol expression are unaffected, and its parts can be \
extracted positionally.\
\>", "Notes",ExpressionUUID->"490cdb3d-4820-4ce8-ae31-41f523d929fd"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[GridBox[{
    {
     StyleBox["Examples", "PrimaryExamplesSection"], ""}
   }],
  $Line = 0; Null]], "PrimaryExamplesSection",ExpressionUUID->"fc9f6ecc-b61c-\
4ea9-bb6b-1c55d2dee74b"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<Knoodle`\>\"", "]"}]], "Input",ExpressionUUID->"1eea1464-b61d-4c81-8417-35e1aa421ea2"],

Cell["\<\
KnoodleIdentify returns KnotSymbol keys; Knot[3,1] identifies as the \
mirror-trefoil coset:\
\>", "ExampleText",ExpressionUUID->"b110c7f0-8239-4833-9f58-274375e7df22"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"KnoodleIdentify", "[", 
  RowBox[{"Knot", "[", 
   RowBox[{"3", ",", " ", "1"}], "]"}], "]"}]], "Input",ExpressionUUID->\
"b9b8fe3d-7081-45ba-9a90-86bacd06ece3"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   InterpretationBox[
    TemplateBox[{
      SubscriptBox["3", "1"], "\"m/mr\""},
     "Superscript"],
    Knoodle`KnotSymbol[3, 1, True, "m/mr"]], "\[Rule]", "1"}], 
  "\[RightAssociation]"}]], "Output",ExpressionUUID->"de25b5d0-de87-496a-a62c-\
75f35cd05e77"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"f5d8bacf-f1ea-46f4-b372-c6dd54a2b36e"],

Cell["\<\
KnotInfo display notation: the coset superscript is suppressed when the coset \
contains e, and knots of 11 or more crossings carry an \
alternating/non-alternating tag:\
\>", "ExampleText",ExpressionUUID->"c875d248-62c1-4698-8fe3-d2ee8d1129fb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"KnotSymbol", "[", 
    RowBox[{"3", ",", " ", "1", ",", " ", "True", ",", " ", "\"\<e/r\>\""}], 
    "]"}], ",", " ", 
   RowBox[{"KnotSymbol", "[", 
    RowBox[{"3", ",", " ", "1", ",", " ", "True", ",", " ", "\"\<m/mr\>\""}], 
    "]"}], ",", " ", 
   RowBox[{"KnotSymbol", "[", 
    RowBox[{
    "11", ",", " ", "456", ",", " ", "True", ",", " ", "\"\<e/r\>\""}], "]"}],
    ",", " ", 
   RowBox[{"KnotSymbol", "[", 
    RowBox[{
    "12", ",", " ", "3541", ",", " ", "False", ",", " ", "\"\<m\>\""}], 
    "]"}]}], "}"}]], "Input",ExpressionUUID->"6989c35e-24e7-4245-928f-\
4a693b7c7595"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   InterpretationBox[
    SubscriptBox["3", "1"],
    Knoodle`KnotSymbol[3, 1, True, "e/r"]], ",", 
   InterpretationBox[
    TemplateBox[{
      SubscriptBox["3", "1"], "\"m/mr\""},
     "Superscript"],
    Knoodle`KnotSymbol[3, 1, True, "m/mr"]], ",", 
   InterpretationBox[
    SubscriptBox["\<\"11a\"\>", "456"],
    Knoodle`KnotSymbol[11, 456, True, "e/r"]], ",", 
   InterpretationBox[
    TemplateBox[{
      SubscriptBox["\"12n\"", "3541"], "\"m\""},
     "Superscript"],
    Knoodle`KnotSymbol[12, 3541, False, "m"]]}], "}"}]], "Output",ExpressionUU\
ID->"57c3a26e-3518-40c8-9d83-473227c4c273"]
}, Open  ]]
}, Open  ]],

