   "]"}], "]"}]], "Input",ExpressionUUID->"acbc67cd-6309-40d7-933b-\
0c5c275748b2"],

Cell[BoxData[
 TagBox[
  StyleBox[
   RowBox[{"KnotSymbol", "[", 
    RowBox[{"3", ",", "1", ",", "True", ",", "\"\<m/mr\>\""}], "]"}],
   ShowSpecialCharacters->False,
   ShowStringCharacters->True,
   NumberMarks->True],
  FullForm]], "Output",ExpressionUUID->"5af4c946-c186-4fd3-bf02-c73f0248afa3"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"0e14b1c0-f878-4d8f-bcc4-c456397be4c5"],

Cell["\<\
Extract the crossing number of an identified knot positionally:\
\>", "ExampleText",ExpressionUUID->"22b4c3a1-1b38-45cb-9901-3a1482ea4b57"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ks", " ", "=", " ", 
    RowBox[{"First", "[", 
     RowBox[{"Keys", "[", 
      RowBox[{"KnoodleIdentify", "[", 
       RowBox[{"Knot", "[", 
        RowBox[{"7", ",", " ", "4"}], "]"}], "]"}], "]"}], "]"}]}], ";"}], 
  " "}]], "Input",ExpressionUUID->"6213195a-8aba-4368-b4eb-b9f95325596c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ks", "[", 
  RowBox[{"[", "1", "]"}], "]"}]], "Input",ExpressionUUID->"dbd9f295-557d-46a1-9cd5-54c671e2f85d"],

Cell[BoxData["7"], "Output",ExpressionUUID->"28765ad7-b46b-4887-8b92-35d8a10d3674"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
