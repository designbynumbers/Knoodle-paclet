      RowBox[{"X", "[", 
       RowBox[{"8", ",", "3", ",", "9", ",", "4"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"6", ",", "14", ",", "7", ",", "13"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"2", ",", "7", ",", "3", ",", "8"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"12", ",", "1", ",", "13", ",", "2"}], "]"}]}], "]"}]}], ";"}],
  
  HoldForm]], "Input",ExpressionUUID->"03846fac-bc18-4d69-b332-7c2728a9bd0b"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"reps", "=", 
    RowBox[{"{", 
     RowBox[{"k932", ",", 
      RowBox[{"reversePD", "[", "k932", "]"}], ",", 
      RowBox[{"mirrorPD", "[", "k932", "]"}], ",", 
      RowBox[{"mirrorPD", "[", 
       RowBox[{"reversePD", "[", "k932", "]"}], "]"}]}], "}"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"b8dfc934-4659-482c-85c6-c927225e3350"],

