      RowBox[{"X", "[", 
       RowBox[{"6", ",", "14", ",", "7", ",", "13"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"2", ",", "7", ",", "3", ",", "8"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"12", ",", "1", ",", "13", ",", "2"}], "]"}]}], "]"}]}], ";"}],
  
  HoldForm]], "Input",ExpressionUUID->"9253906e-4fc7-4e61-86ec-bfc7adaf82a2"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"reps", "=", 
    RowBox[{"{", 
     RowBox[{"k932", ",", 
      RowBox[{"reversePD", "[", "k932", "]"}], ",", 
      RowBox[{"mirrorPD", "[", "k932", "]"}], ",", 
      RowBox[{"mirrorPD", "[", 
       RowBox[{"reversePD", "[", "k932", "]"}], "]"}]}], "}"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"06e98509-956a-464d-8f08-deee2a8498e1"],

