Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"2c85e633-4ca9-484e-b74d-2f78de6f1273"],

Cell["\<\
Restricting \"MaxCrossings\" below a knot's crossing number forces a NotFound \
result:\
\>", "ExampleText",ExpressionUUID->"0a328b41-72a7-4c21-9132-c90746106f72"],

Cell[CellGroupData[{

Cell[BoxData[
 TagBox[
  RowBox[{"KnoodleIdentify", "[", 
   RowBox[{
    RowBox[{"Knot", "[", 
     RowBox[{"5", ",", "1"}], "]"}], ",", 
    RowBox[{"\"\<MaxCrossings\>\"", "\[Rule]", "3"}]}], "]"}],
  HoldForm]], "Input",ExpressionUUID->"1a5500db-49c9-4dc3-810d-cdfdae468d22"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"NotFound", "[", 
    RowBox[{"5", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"4", ",", "9", ",", "5", ",", "0", ",", 
         RowBox[{"-", "1"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "5", ",", "1", ",", "6", ",", 
         RowBox[{"-", "1"}]}], "}"}], ",", 
       RowBox[{"{", 
