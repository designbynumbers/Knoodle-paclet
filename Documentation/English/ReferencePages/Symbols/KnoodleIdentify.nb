Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"2505277d-63ba-4b49-a201-7e728458b277"],

Cell["\<\
9_32 is chiral and noninvertible, so its four symmetry variants (identity, \
reverse, mirror, mirror-reverse) are four genuinely different oriented knots, \
and KnoodleIdentify assigns each its own coset. Mirroring a PD code flips \
every crossing; reversal renumbers the arcs backwards:\
\>", "ExampleText",ExpressionUUID->"d1988e7b-8ca2-491b-8a88-efeb275b8f17"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"mirrorPD", "[", "p_PD", "]"}], " ", ":=", " ", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"n", " ", "=", " ", 
        RowBox[{"Length", "[", "p", "]"}]}], "}"}], ",", " ", 
      RowBox[{"Replace", "[", 
       RowBox[{"p", ",", " ", 
        RowBox[{
         RowBox[{"X", "[", 
          RowBox[{"i_", ",", " ", "j_", ",", " ", "k_", ",", " ", "l_"}], 
          "]"}], " ", ":>", " ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Mod", "[", 
             RowBox[{
              RowBox[{"l", " ", "-", " ", "j"}], ",", " ", 
              RowBox[{"2", "*", "n"}]}], "]"}], " ", "==", " ", "1"}], ",", 
           " ", 
           RowBox[{"X", "[", 
            RowBox[{"j", ",", " ", "k", ",", " ", "l", ",", " ", "i"}], "]"}],
            ",", " ", 
           RowBox[{"X", "[", 
            RowBox[{"l", ",", " ", "i", ",", " ", "j", ",", " ", "k"}], 
            "]"}]}], "]"}]}], ",", " ", "1"}], "]"}]}], "]"}]}], ";"}], 
  " "}]], "Input",ExpressionUUID->"b57af707-7e67-4a89-98c4-5e82addfae78"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"reversePD", "[", "p_PD", "]"}], " ", ":=", " ", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"s", " ", "=", " ", 
        RowBox[{
         RowBox[{"2", "*", 
          RowBox[{"Length", "[", "p", "]"}]}], " ", "+", " ", "1"}]}], "}"}], 
      ",", " ", 
      RowBox[{"Replace", "[", 
       RowBox[{"p", ",", " ", 
        RowBox[{
         RowBox[{"X", "[", 
          RowBox[{"i_", ",", " ", "j_", ",", " ", "k_", ",", " ", "l_"}], 
          "]"}], " ", ":>", " ", 
         RowBox[{"X", "[", 
          RowBox[{
           RowBox[{"s", " ", "-", " ", "k"}], ",", " ", 
           RowBox[{"s", " ", "-", " ", "l"}], ",", " ", 
           RowBox[{"s", " ", "-", " ", "i"}], ",", " ", 
           RowBox[{"s", " ", "-", " ", "j"}]}], "]"}]}], ",", " ", "1"}], 
       "]"}]}], "]"}]}], ";"}], " "}]], "Input",ExpressionUUID->"2f34caf9-\
29cb-4d5a-8a93-bdd8b1608986"],

