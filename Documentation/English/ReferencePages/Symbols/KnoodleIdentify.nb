Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"cada51fe-a6a3-4334-b40a-146f2b065938"],

Cell["\<\
A knot with more crossings than the lookup table covers comes back as \
Unidentified together with its signed PD code. Here a (2,17) torus knot is \
sampled as a space curve:\
\>", "ExampleText",ExpressionUUID->"51b8e153-3e0e-4cb7-a471-38753c2c6dbd"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"torus", "=", 
    RowBox[{"Most", "[", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"N", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"2", " ", "t"}], "]"}], " ", 
           RowBox[{"(", 
            RowBox[{"2", "+", 
             RowBox[{"Cos", "[", 
              RowBox[{"17", " ", "t"}], "]"}]}], ")"}]}], ",", 
          RowBox[{
           RowBox[{"Sin", "[", 
            RowBox[{"2", " ", "t"}], "]"}], " ", 
           RowBox[{"(", 
            RowBox[{"2", "+", 
             RowBox[{"Cos", "[", 
              RowBox[{"17", " ", "t"}], "]"}]}], ")"}]}], ",", 
          RowBox[{"Sin", "[", 
           RowBox[{"17", " ", "t"}], "]"}]}], "}"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0.`", ",", 
         RowBox[{"2", " ", "\[Pi]"}], ",", 
         FractionBox[
          RowBox[{"2", " ", "\[Pi]"}], "680"]}], "}"}]}], "]"}], "]"}]}], 
   ";"}],
  HoldForm]], "Input",ExpressionUUID->"d85fbfc2-5845-4b32-85d6-2d173cf5a03e"],

Cell[CellGroupData[{

Cell[BoxData[
 TagBox[
  RowBox[{"KnoodleIdentify", "[", "torus", "]"}],
  HoldForm]], "Input",ExpressionUUID->"748b6ed8-3824-43ea-ae41-6916119d05cf"],

