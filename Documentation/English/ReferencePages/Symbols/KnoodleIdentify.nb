Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"74e33f0c-34b1-438f-b003-54c77d829676"],

Cell["\<\
A composite knot reports each distinct prime factor with its multiplicity. \
The granny knot is the connect sum of two like-handed trefoils, given here as \
two PD-code summands:\
\>", "ExampleText",ExpressionUUID->"8f23b636-ee7f-47bd-a801-1fa497f30082"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"granny", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"5", ",", " ", "2", ",", " ", "0", ",", " ", "3", ",", " ", 
          RowBox[{"-", "1"}], ",", " ", "3", ",", " ", "3"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"3", ",", " ", "0", ",", " ", "4", ",", " ", "1", ",", " ", 
          RowBox[{"-", "1"}], ",", " ", "3", ",", " ", "3"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "4", ",", " ", "2", ",", " ", "5", ",", " ", 
          RowBox[{"-", "1"}], ",", " ", "3", ",", " ", "3"}], "}"}]}], "}"}], 
      ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"5", ",", " ", "2", ",", " ", "0", ",", " ", "3", ",", " ", 
          RowBox[{"-", "1"}], ",", " ", "3", ",", " ", "3"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"3", ",", " ", "0", ",", " ", "4", ",", " ", "1", ",", " ", 
          RowBox[{"-", "1"}], ",", " ", "3", ",", " ", "3"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "4", ",", " ", "2", ",", " ", "5", ",", " ", 
          RowBox[{"-", "1"}], ",", " ", "3", ",", " ", "3"}], "}"}]}], 
       "}"}]}], "}"}]}], ";"}], " "}]], "Input",ExpressionUUID->"31ee89fd-\
38c5-4598-95ce-9b44d7597435"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"KnoodleIdentify", "[", "granny", "]"}]], "Input",ExpressionUUID->"90e77b80-083f-4567-b6c4-af8d99098765"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   InterpretationBox[
    TemplateBox[{
      SubscriptBox["3", "1"], "\"m/mr\""},
     "Superscript"],
    Knoodle`KnotSymbol[3, 1, True, "m/mr"]], "\[Rule]", "2"}], 
  "\[RightAssociation]"}]], "Output",ExpressionUUID->"572a0ce7-d09b-427e-b9ec-\
6c5e751a53e7"]
}, Open  ]]
}, Open  ]],

