Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"b9d4f1e6-534b-4f7e-9aeb-84df8118b884"],

Cell["\<\
Both KnoodleSimplify and KnoodleIdentify handle large geometric input \
quickly. Generate a Gaussian random polygon with 5000 vertices:\
\>", "ExampleText",ExpressionUUID->"adaa8f01-8527-486a-a409-a109dbbb5093"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"GaussianRandomPolygon", "[", "n_", "]"}], ":=", 
   RowBox[{"Accumulate", "[", 
    RowBox[{"Standardize", "[", 
     RowBox[{
      RowBox[{"RandomVariate", "[", 
       RowBox[{
        RowBox[{"NormalDistribution", "[", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "3"}], "}"}]}], "]"}], ",", "Mean", ",", 
      RowBox[{"1", "&"}]}], "]"}], "]"}]}],
  HoldForm]], "Input",ExpressionUUID->"752a1672-c7a0-4c8c-be96-b2d63786cd80"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"SeedRandom", "[", "1", "]"}], ";", 
   RowBox[{"P", "=", 
    RowBox[{"GaussianRandomPolygon", "[", "5000", "]"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"c4eff735-85da-4f48-9c84-05a310f45ecb"],

Cell["\<\
Simplifying decomposes it into a connect sum of 14 prime summands, in a few \
hundredths of a second:\
\>", "ExampleText",ExpressionUUID->"fa7233e5-ec7c-4fb8-b8d5-12be31c4779e"],

Cell[CellGroupData[{

