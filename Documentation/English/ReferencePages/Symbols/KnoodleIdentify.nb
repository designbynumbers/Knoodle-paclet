Cell["\<\
Restricting \"MaxCrossings\" below a knot's crossing number forces a NotFound \
result:\
\>", "ExampleText",ExpressionUUID->"a68fdb4a-46c9-4c3f-9709-9236eec630fe"],

Cell[CellGroupData[{

Cell[BoxData[
 TagBox[
  RowBox[{"KnoodleIdentify", "[", 
   RowBox[{
    RowBox[{"Knot", "[", 
     RowBox[{"5", ",", "1"}], "]"}], ",", 
    RowBox[{"\"\<MaxCrossings\>\"", "\[Rule]", "3"}]}], "]"}],
  HoldForm]], "Input",ExpressionUUID->"9602f842-9dd8-4599-9382-2318a17fbb19"],

