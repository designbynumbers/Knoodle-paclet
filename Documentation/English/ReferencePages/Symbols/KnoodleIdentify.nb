Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"5e53f93e-ecbe-46be-a9eb-074a2a1ab1f4"],

Cell["\<\
A composite knot reports each distinct prime factor with its multiplicity. \
The granny knot is the connect sum of two like-handed trefoils, given here as \
two PD-code summands:\
\>", "ExampleText",ExpressionUUID->"3f4d110d-6dde-4f42-9e65-aa603f9bf826"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"granny", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"5", ",", "2", ",", "0", ",", "3", ",", 
          RowBox[{"-", "1"}], ",", "3", ",", "3"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"3", ",", "0", ",", "4", ",", "1", ",", 
          RowBox[{"-", "1"}], ",", "3", ",", "3"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "4", ",", "2", ",", "5", ",", 
          RowBox[{"-", "1"}], ",", "3", ",", "3"}], "}"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"5", ",", "2", ",", "0", ",", "3", ",", 
          RowBox[{"-", "1"}], ",", "3", ",", "3"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"3", ",", "0", ",", "4", ",", "1", ",", 
          RowBox[{"-", "1"}], ",", "3", ",", "3"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "4", ",", "2", ",", "5", ",", 
          RowBox[{"-", "1"}], ",", "3", ",", "3"}], "}"}]}], "}"}]}], "}"}]}],
    ";"}],
  HoldForm]], "Input",ExpressionUUID->"8810c215-885e-42b4-8d27-65e55706f970"],

Cell[CellGroupData[{

Cell[BoxData[
 TagBox[
  RowBox[{"KnoodleIdentify", "[", "granny", "]"}],
  HoldForm]], "Input",ExpressionUUID->"19ede759-1233-45e2-85ea-f91f16d39c9d"],

