Cell["", "ExampleDelimiter",ExpressionUUID->"438504bb-06bb-42da-a547-a8220ed6dbe2"],

Cell["\<\
A composite knot reports each distinct prime factor with its multiplicity. \
The granny knot is the connect sum of two like-handed trefoils, given here as \
two PD-code summands:\
\>", "ExampleText",ExpressionUUID->"b559da4d-3e17-448b-b063-8c2c1eb8c23f"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"granny", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"5", ",", "2", ",", "0", ",", "3", ",", 
          RowBox[{"-", "1"}], ",", "3", ",", "3"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"3", ",", "0", ",", "4", ",", "1", ",", 
          RowBox[{"-", "1"}], ",", "3", ",", "3"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "4", ",", "2", ",", "5", ",", 
          RowBox[{"-", "1"}], ",", "3", ",", "3"}], "}"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"5", ",", "2", ",", "0", ",", "3", ",", 
          RowBox[{"-", "1"}], ",", "3", ",", "3"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"3", ",", "0", ",", "4", ",", "1", ",", 
          RowBox[{"-", "1"}], ",", "3", ",", "3"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "4", ",", "2", ",", "5", ",", 
          RowBox[{"-", "1"}], ",", "3", ",", "3"}], "}"}]}], "}"}]}], "}"}]}],
    ";"}],
  HoldForm]], "Input",ExpressionUUID->"3bd1f110-183b-4884-b8c8-52a568362488"],

Cell[CellGroupData[{

