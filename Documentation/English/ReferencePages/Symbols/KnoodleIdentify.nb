      RowBox[{"X", "[", 
       RowBox[{"21", ",", "10", ",", "22", ",", "11"}], "]"}]}], "]"}]}], 
   ";"}],
  HoldForm]], "Input",ExpressionUUID->"7602de66-b6b4-4438-95c4-00cd3da2ef71"],

