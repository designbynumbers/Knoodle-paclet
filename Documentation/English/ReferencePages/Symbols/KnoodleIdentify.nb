Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"e2737df5-599e-46b0-a9dc-81fbd989d929"],

Cell["\<\
A knot with more crossings than the lookup table covers comes back as \
Unidentified together with its signed PD code. Here a (2,17) torus knot is \
sampled as a space curve:\
\>", "ExampleText",ExpressionUUID->"4e950675-93ad-4f74-9983-1b6f41a10c97"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"torus", " ", "=", " ", 
    RowBox[{"Most", "[", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"N", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"2", "*", "t"}], "]"}], "*", 
           RowBox[{"(", 
            RowBox[{"2", " ", "+", " ", 
             RowBox[{"Cos", "[", 
              RowBox[{"17", "*", "t"}], "]"}]}], ")"}]}], ",", " ", 
          RowBox[{
           RowBox[{"Sin", "[", 
            RowBox[{"2", "*", "t"}], "]"}], "*", 
           RowBox[{"(", 
            RowBox[{"2", " ", "+", " ", 
             RowBox[{"Cos", "[", 
              RowBox[{"17", "*", "t"}], "]"}]}], ")"}]}], ",", " ", 
          RowBox[{"Sin", "[", 
           RowBox[{"17", "*", "t"}], "]"}]}], "}"}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"t", ",", " ", "0.", ",", " ", 
         RowBox[{"2", "*", "Pi"}], ",", " ", 
         RowBox[{"2", "*", 
          RowBox[{"(", 
           RowBox[{"Pi", "/", "680"}], ")"}]}]}], "}"}]}], "]"}], "]"}]}], 
   ";"}], " "}]], "Input",ExpressionUUID->"bf454dda-3932-4d43-83f4-\
0204c10f5fcd"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"KnoodleIdentify", "[", "torus", "]"}]], "Input",ExpressionUUID->"88e98eda-c381-4093-b7a2-6f63fa25f63e"],

