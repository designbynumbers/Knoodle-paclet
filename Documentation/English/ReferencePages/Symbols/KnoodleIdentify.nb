Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"1bab082b-6559-43cd-8394-18344166d0c0"],

Cell["\<\
9_32 is chiral and noninvertible, so its four symmetry variants (identity, \
reverse, mirror, mirror-reverse) are four genuinely different oriented knots, \
and KnoodleIdentify assigns each its own coset. Mirroring a PD code flips \
every crossing; reversal renumbers the arcs backwards:\
\>", "ExampleText",ExpressionUUID->"fc07074a-a9ce-4f16-ab39-a46c5faecf18"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{
    RowBox[{"mirrorPD", "[", "p_PD", "]"}], ":=", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"n", "=", 
        RowBox[{"Length", "[", "p", "]"}]}], "}"}], ",", 
      RowBox[{"Replace", "[", 
       RowBox[{"p", ",", 
        RowBox[{
         RowBox[{"X", "[", 
          RowBox[{"i_", ",", "j_", ",", "k_", ",", "l_"}], "]"}], "\[RuleDelayed]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Mod", "[", 
             RowBox[{
              RowBox[{"l", "-", "j"}], ",", 
              RowBox[{"2", " ", "n"}]}], "]"}], "\[Equal]", "1"}], ",", 
           RowBox[{"X", "[", 
            RowBox[{"j", ",", "k", ",", "l", ",", "i"}], "]"}], ",", 
           RowBox[{"X", "[", 
            RowBox[{"l", ",", "i", ",", "j", ",", "k"}], "]"}]}], "]"}]}], ",",
         "1"}], "]"}]}], "]"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"885ef8d7-1ee5-4790-9b84-1c551cf44b19"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{
    RowBox[{"reversePD", "[", "p_PD", "]"}], ":=", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"s", "=", 
        RowBox[{
         RowBox[{"2", " ", 
          RowBox[{"Length", "[", "p", "]"}]}], "+", "1"}]}], "}"}], ",", 
      RowBox[{"Replace", "[", 
       RowBox[{"p", ",", 
        RowBox[{
         RowBox[{"X", "[", 
          RowBox[{"i_", ",", "j_", ",", "k_", ",", "l_"}], "]"}], "\[RuleDelayed]", 
         RowBox[{"X", "[", 
          RowBox[{
           RowBox[{"s", "-", "k"}], ",", 
           RowBox[{"s", "-", "l"}], ",", 
           RowBox[{"s", "-", "i"}], ",", 
           RowBox[{"s", "-", "j"}]}], "]"}]}], ",", "1"}], "]"}]}], "]"}]}], 
   ";"}],
  HoldForm]], "Input",ExpressionUUID->"0b2f58f8-4d83-4d9b-8d60-56bce2e1ce2f"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"k932", "=", 
    RowBox[{"PD", "[", 
     RowBox[{
      RowBox[{"X", "[", 
       RowBox[{"14", ",", "18", ",", "15", ",", "17"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"18", ",", "6", ",", "1", ",", "5"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"10", ",", "15", ",", "11", ",", "16"}], "]"}], ",", 
      RowBox[{"X", "[", 
