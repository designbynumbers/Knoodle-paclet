Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"\[LeftAssociation]", 
    RowBox[{
     InterpretationBox[
      SubscriptBox["9", "32"],
      Knoodle`KnotSymbol[9, 32, True, "e"]], "\[Rule]", "1"}], 
    "\[RightAssociation]"}], ",", 
   RowBox[{"\[LeftAssociation]", 
    RowBox[{
     InterpretationBox[
      TemplateBox[{
        SubscriptBox["9", "32"], "\"r\""},
       "Superscript"],
      Knoodle`KnotSymbol[9, 32, True, "r"]], "\[Rule]", "1"}], 
    "\[RightAssociation]"}], ",", 
   RowBox[{"\[LeftAssociation]", 
    RowBox[{
     InterpretationBox[
      TemplateBox[{
        SubscriptBox["9", "32"], "\"m\""},
       "Superscript"],
      Knoodle`KnotSymbol[9, 32, True, "m"]], "\[Rule]", "1"}], 
    "\[RightAssociation]"}], ",", 
   RowBox[{"\[LeftAssociation]", 
    RowBox[{
     InterpretationBox[
