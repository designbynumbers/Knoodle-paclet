Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"395b37ff-eda7-4986-a01f-7f5004897e4b"],

Cell["\<\
Both KnoodleSimplify and KnoodleIdentify handle large geometric input \
quickly. Generate a Gaussian random polygon with 5000 vertices:\
\>", "ExampleText",ExpressionUUID->"9825d1cb-b1c8-4d5b-b1e2-12c5c52a9d37"],

Cell[BoxData[
 RowBox[{
  RowBox[{"GaussianRandomPolygon", "[", "n_", "]"}], " ", ":=", " ", 
  RowBox[{"Accumulate", "[", 
   RowBox[{"Standardize", "[", 
    RowBox[{
