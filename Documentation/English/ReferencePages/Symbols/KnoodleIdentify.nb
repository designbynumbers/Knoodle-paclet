Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"9b932e5a-e096-4704-8d34-06d239fdeabf"],

Cell["\<\
Both KnoodleSimplify and KnoodleIdentify handle large geometric input \
quickly. Generate a Gaussian random polygon with 5000 vertices:\
\>", "ExampleText",ExpressionUUID->"b35b75f8-5b9c-4552-840a-aa1e1d55c22b"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"GaussianRandomPolygon", "[", "n_", "]"}], ":=", 
   RowBox[{"Accumulate", "[", 
    RowBox[{"Standardize", "[", 
     RowBox[{
      RowBox[{"RandomVariate", "[", 
       RowBox[{
        RowBox[{"NormalDistribution", "[", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "3"}], "}"}]}], "]"}], ",", "Mean", ",", 
      RowBox[{"1", "&"}]}], "]"}], "]"}]}],
  HoldForm]], "Input",ExpressionUUID->"e35abe39-2184-4d8b-b333-90bcbec0d5fc"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"SeedRandom", "[", "1", "]"}], ";", 
   RowBox[{"P", "=", 
    RowBox[{"GaussianRandomPolygon", "[", "5000", "]"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"b838e986-940a-48f3-8891-b6a7221a600f"],

Cell["\<\
Simplifying decomposes it into a connect sum of 14 prime summands, in a few \
hundredths of a second:\
\>", "ExampleText",ExpressionUUID->"ee3c3984-6118-46e5-879a-bc15d6785f41"],

