Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"149e4754-393a-4501-9b61-1f903f51fd40"],

Cell["\<\
Both KnoodleSimplify and KnoodleIdentify handle large geometric input \
quickly. Generate a Gaussian random polygon with 5000 vertices:\
\>", "ExampleText",ExpressionUUID->"8d76f74a-d7c6-4c43-8de5-29a2f0c43f5a"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"GaussianRandomPolygon", "[", "n_", "]"}], ":=", 
   RowBox[{"Accumulate", "[", 
    RowBox[{"Standardize", "[", 
     RowBox[{
      RowBox[{"RandomVariate", "[", 
       RowBox[{
        RowBox[{"NormalDistribution", "[", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "3"}], "}"}]}], "]"}], ",", "Mean", ",", 
      RowBox[{"1", "&"}]}], "]"}], "]"}]}],
  HoldForm]], "Input",ExpressionUUID->"a182f768-db72-4a48-a8e0-5b5405f5dc9c"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"SeedRandom", "[", "1", "]"}], ";", 
   RowBox[{"P", "=", 
    RowBox[{"GaussianRandomPolygon", "[", "5000", "]"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"f6567231-610c-478a-89da-45f7be610098"],

Cell["\<\
Simplifying decomposes it into a connect sum of 14 prime summands, in a few \
hundredths of a second:\
\>", "ExampleText",ExpressionUUID->"4aeff023-8692-4014-a8b9-b68da759e7eb"],

