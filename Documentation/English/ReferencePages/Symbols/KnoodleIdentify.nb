Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"d44513b7-3bbe-49b9-a813-140b87b074eb"],

Cell["\<\
9_32 is chiral and noninvertible, so its four symmetry variants (identity, \
reverse, mirror, mirror-reverse) are four genuinely different oriented knots, \
and KnoodleIdentify assigns each its own coset. Mirroring a PD code flips \
every crossing; reversal renumbers the arcs backwards:\
\>", "ExampleText",ExpressionUUID->"83406385-ee45-4640-98e1-7be8b398b2dc"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{
    RowBox[{"mirrorPD", "[", "p_PD", "]"}], ":=", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"n", "=", 
        RowBox[{"Length", "[", "p", "]"}]}], "}"}], ",", 
      RowBox[{"Replace", "[", 
       RowBox[{"p", ",", 
        RowBox[{
         RowBox[{"X", "[", 
          RowBox[{"i_", ",", "j_", ",", "k_", ",", "l_"}], "]"}], "\[RuleDelayed]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Mod", "[", 
             RowBox[{
              RowBox[{"l", "-", "j"}], ",", 
              RowBox[{"2", " ", "n"}]}], "]"}], "\[Equal]", "1"}], ",", 
           RowBox[{"X", "[", 
            RowBox[{"j", ",", "k", ",", "l", ",", "i"}], "]"}], ",", 
           RowBox[{"X", "[", 
            RowBox[{"l", ",", "i", ",", "j", ",", "k"}], "]"}]}], "]"}]}], ",",
         "1"}], "]"}]}], "]"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"e557ef0c-d9cb-45c3-90e3-15db2b6cfd66"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{
    RowBox[{"reversePD", "[", "p_PD", "]"}], ":=", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"s", "=", 
        RowBox[{
         RowBox[{"2", " ", 
          RowBox[{"Length", "[", "p", "]"}]}], "+", "1"}]}], "}"}], ",", 
      RowBox[{"Replace", "[", 
       RowBox[{"p", ",", 
        RowBox[{
         RowBox[{"X", "[", 
          RowBox[{"i_", ",", "j_", ",", "k_", ",", "l_"}], "]"}], "\[RuleDelayed]", 
         RowBox[{"X", "[", 
          RowBox[{
           RowBox[{"s", "-", "k"}], ",", 
           RowBox[{"s", "-", "l"}], ",", 
           RowBox[{"s", "-", "i"}], ",", 
           RowBox[{"s", "-", "j"}]}], "]"}]}], ",", "1"}], "]"}]}], "]"}]}], 
   ";"}],
  HoldForm]], "Input",ExpressionUUID->"688aa398-768f-4020-b57f-143c86869659"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"k932", "=", 
    RowBox[{"PD", "[", 
     RowBox[{
      RowBox[{"X", "[", 
       RowBox[{"14", ",", "18", ",", "15", ",", "17"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"18", ",", "6", ",", "1", ",", "5"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"10", ",", "15", ",", "11", ",", "16"}], "]"}], ",", 
