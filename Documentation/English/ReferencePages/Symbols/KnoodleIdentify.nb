Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"a3f66277-2179-4cc8-a662-71d0a484c95b"],

Cell["\<\
Restricting \"MaxCrossings\" below a knot's crossing number forces a NotFound \
result:\
\>", "ExampleText",ExpressionUUID->"866e1739-b500-4ff0-b5ce-93303bded94f"],

Cell[CellGroupData[{

Cell[BoxData[
 TagBox[
  RowBox[{"KnoodleIdentify", "[", 
   RowBox[{
    RowBox[{"Knot", "[", 
     RowBox[{"5", ",", "1"}], "]"}], ",", 
    RowBox[{"\"\<MaxCrossings\>\"", "\[Rule]", "3"}]}], "]"}],
  HoldForm]], "Input",ExpressionUUID->"fc06c867-840a-4ccf-91dd-a04cf3370987"],

