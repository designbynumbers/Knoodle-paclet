Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"ceaa5d65-88d2-451b-aa19-44d4bf1949a9"],

Cell["\<\
Lookup is by knot type, not by polynomial invariants, so KnoodleIdentify \
distinguishes the famous mutant pair that shares Alexander and Jones \
polynomials: the Conway knot (11n34) and the Kinoshita-Terasaka knot (11n42):\
\
\>", "ExampleText",ExpressionUUID->"a95ab6f9-9ec7-4c6e-adbd-83ad3d70c7e1"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"conway", "=", 
    RowBox[{"PD", "[", 
     RowBox[{
      RowBox[{"X", "[", 
       RowBox[{"4", ",", "2", ",", "5", ",", "1"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"8", ",", "4", ",", "9", ",", "3"}], "]"}], ",", 
      RowBox[{"X", "[", 
