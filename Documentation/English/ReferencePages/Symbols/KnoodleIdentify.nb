Cell["", "ExampleDelimiter",ExpressionUUID->"b5285a8f-30f0-4f00-99ec-3f32c9ade17b"],

Cell["\<\
Lookup is by knot type, not by polynomial invariants, so KnoodleIdentify \
distinguishes the famous mutant pair that shares Alexander and Jones \
polynomials: the Conway knot (11n34) and the Kinoshita-Terasaka knot (11n42):\
\
\>", "ExampleText",ExpressionUUID->"aa09acb1-fee5-42e7-befb-b6ae1c612a15"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"conway", "=", 
    RowBox[{"PD", "[", 
     RowBox[{
      RowBox[{"X", "[", 
       RowBox[{"4", ",", "2", ",", "5", ",", "1"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"8", ",", "4", ",", "9", ",", "3"}], "]"}], ",", 
      RowBox[{"X", "[", 
