Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"52a116ad-20b5-4234-8263-b574632c2b23"],

Cell["\<\
9_32 is chiral and noninvertible, so its four symmetry variants (identity, \
reverse, mirror, mirror-reverse) are four genuinely different oriented knots, \
and KnoodleIdentify assigns each its own coset. Mirroring a PD code flips \
every crossing; reversal renumbers the arcs backwards:\
\>", "ExampleText",ExpressionUUID->"d3345ca6-6ec4-43ad-b93a-c2799283abb0"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{
    RowBox[{"mirrorPD", "[", "p_PD", "]"}], ":=", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"n", "=", 
        RowBox[{"Length", "[", "p", "]"}]}], "}"}], ",", 
      RowBox[{"Replace", "[", 
       RowBox[{"p", ",", 
        RowBox[{
         RowBox[{"X", "[", 
          RowBox[{"i_", ",", "j_", ",", "k_", ",", "l_"}], "]"}], "\[RuleDelayed]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Mod", "[", 
             RowBox[{
              RowBox[{"l", "-", "j"}], ",", 
              RowBox[{"2", " ", "n"}]}], "]"}], "\[Equal]", "1"}], ",", 
           RowBox[{"X", "[", 
            RowBox[{"j", ",", "k", ",", "l", ",", "i"}], "]"}], ",", 
           RowBox[{"X", "[", 
            RowBox[{"l", ",", "i", ",", "j", ",", "k"}], "]"}]}], "]"}]}], ",",
         "1"}], "]"}]}], "]"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"80f9a2c9-2b85-4620-b73c-e44356b13c00"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{
    RowBox[{"reversePD", "[", "p_PD", "]"}], ":=", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"s", "=", 
        RowBox[{
         RowBox[{"2", " ", 
          RowBox[{"Length", "[", "p", "]"}]}], "+", "1"}]}], "}"}], ",", 
      RowBox[{"Replace", "[", 
       RowBox[{"p", ",", 
        RowBox[{
         RowBox[{"X", "[", 
          RowBox[{"i_", ",", "j_", ",", "k_", ",", "l_"}], "]"}], "\[RuleDelayed]", 
         RowBox[{"X", "[", 
          RowBox[{
           RowBox[{"s", "-", "k"}], ",", 
           RowBox[{"s", "-", "l"}], ",", 
           RowBox[{"s", "-", "i"}], ",", 
           RowBox[{"s", "-", "j"}]}], "]"}]}], ",", "1"}], "]"}]}], "]"}]}], 
   ";"}],
  HoldForm]], "Input",ExpressionUUID->"cc4c12a6-93eb-4189-847c-41f9752e2283"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"k932", "=", 
    RowBox[{"PD", "[", 
     RowBox[{
      RowBox[{"X", "[", 
       RowBox[{"14", ",", "18", ",", "15", ",", "17"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"18", ",", "6", ",", "1", ",", "5"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"10", ",", "15", ",", "11", ",", "16"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"16", ",", "9", ",", "17", ",", "10"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"4", ",", "11", ",", "5", ",", "12"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"8", ",", "3", ",", "9", ",", "4"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"6", ",", "14", ",", "7", ",", "13"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"2", ",", "7", ",", "3", ",", "8"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"12", ",", "1", ",", "13", ",", "2"}], "]"}]}], "]"}]}], ";"}],
  
  HoldForm]], "Input",ExpressionUUID->"3c05feac-cc6a-4798-9ec8-e05720b0dec2"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"reps", "=", 
    RowBox[{"{", 
     RowBox[{"k932", ",", 
      RowBox[{"reversePD", "[", "k932", "]"}], ",", 
      RowBox[{"mirrorPD", "[", "k932", "]"}], ",", 
      RowBox[{"mirrorPD", "[", 
       RowBox[{"reversePD", "[", "k932", "]"}], "]"}]}], "}"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"88411b41-a624-49f2-b70a-e03b5140d3e0"],

