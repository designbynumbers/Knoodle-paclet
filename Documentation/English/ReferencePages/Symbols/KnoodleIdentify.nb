Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"d9624a61-b817-4c49-9ca4-282019d1f125"],

Cell["\<\
A composite knot reports each distinct prime factor with its multiplicity. \
The granny knot is the connect sum of two like-handed trefoils, given here as \
two PD-code summands:\
\>", "ExampleText",ExpressionUUID->"e7fdce35-c3a6-443b-b3da-492bd6443970"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"granny", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"5", ",", "2", ",", "0", ",", "3", ",", 
          RowBox[{"-", "1"}], ",", "3", ",", "3"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"3", ",", "0", ",", "4", ",", "1", ",", 
          RowBox[{"-", "1"}], ",", "3", ",", "3"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "4", ",", "2", ",", "5", ",", 
          RowBox[{"-", "1"}], ",", "3", ",", "3"}], "}"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"5", ",", "2", ",", "0", ",", "3", ",", 
          RowBox[{"-", "1"}], ",", "3", ",", "3"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"3", ",", "0", ",", "4", ",", "1", ",", 
          RowBox[{"-", "1"}], ",", "3", ",", "3"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "4", ",", "2", ",", "5", ",", 
          RowBox[{"-", "1"}], ",", "3", ",", "3"}], "}"}]}], "}"}]}], "}"}]}],
    ";"}],
  HoldForm]], "Input",ExpressionUUID->"f8cf32ec-fd25-4424-b379-293138151c89"],

Cell[CellGroupData[{

Cell[BoxData[
 TagBox[
  RowBox[{"KnoodleIdentify", "[", "granny", "]"}],
  HoldForm]], "Input",ExpressionUUID->"d73c0f13-b9ef-4ecf-b228-586e7513188e"],

