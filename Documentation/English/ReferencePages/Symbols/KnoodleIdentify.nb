      RowBox[{"X", "[", 
       RowBox[{"9", ",", "17", ",", "10", ",", "16"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"11", ",", "18", ",", "12", ",", "19"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"6", ",", "13", ",", "7", ",", "14"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"15", ",", "20", ",", "16", ",", "21"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"17", ",", "1", ",", "18", ",", "22"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"19", ",", "14", ",", "20", ",", "15"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"21", ",", "10", ",", "22", ",", "11"}], "]"}]}], "]"}]}], 
   ";"}],
  HoldForm]], "Input",ExpressionUUID->"000d0f33-7bdc-4dd5-a580-995b997c0844"],

