      RowBox[{"X", "[", 
       RowBox[{"6", ",", "13", ",", "7", ",", "14"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"15", ",", "20", ",", "16", ",", "21"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"17", ",", "1", ",", "18", ",", "22"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"19", ",", "14", ",", "20", ",", "15"}], "]"}], ",", 
      RowBox[{"X", "[", 
       RowBox[{"21", ",", "10", ",", "22", ",", "11"}], "]"}]}], "]"}]}], 
   ";"}],
  HoldForm]], "Input",ExpressionUUID->"7ec81416-efaa-403d-99e2-62d728befdfb"],

