Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"8143defb-6d21-4ea1-89f0-0b77084c48e9"],

Cell["\<\
A knot with more crossings than the lookup table covers comes back as \
Unidentified together with its signed PD code. Here a (2,17) torus knot is \
sampled and tilted into general position:\
\>", "ExampleText",ExpressionUUID->"700b6f04-9cc6-431a-b5d0-794c2ed56292"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"torus", "=", 
    RowBox[{"Most", "[", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"N", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"2", " ", "t"}], "]"}], " ", 
           RowBox[{"(", 
            RowBox[{"2", "+", 
             RowBox[{"Cos", "[", 
              RowBox[{"17", " ", "t"}], "]"}]}], ")"}]}], ",", 
          RowBox[{
           RowBox[{"Sin", "[", 
            RowBox[{"2", " ", "t"}], "]"}], " ", 
           RowBox[{"(", 
            RowBox[{"2", "+", 
             RowBox[{"Cos", "[", 
              RowBox[{"17", " ", "t"}], "]"}]}], ")"}]}], ",", 
          RowBox[{"Sin", "[", 
           RowBox[{"17", " ", "t"}], "]"}]}], "}"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0.`", ",", 
         RowBox[{"2", " ", "\[Pi]"}], ",", 
         FractionBox[
          RowBox[{"2", " ", "\[Pi]"}], "680"]}], "}"}]}], "]"}], "]"}]}], 
   ";"}],
  HoldForm]], "Input",ExpressionUUID->"7398a2ee-4757-4e70-8000-bbdde7857417"],

Cell[CellGroupData[{

Cell[BoxData[
 TagBox[
  RowBox[{"KnoodleIdentify", "[", 
   RowBox[{
    RowBox[{"RotationTransform", "[", 
     RowBox[{"0.4`", ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2", ",", "3"}], "}"}]}], "]"}], "/@", "torus"}], 
   "]"}],
  HoldForm]], "Input",ExpressionUUID->"394410a2-941e-42d9-bb22-843a22a49a1d"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"Unidentified", "[", 
    RowBox[{"17", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"16", ",", "33", ",", "17", ",", "0", ",", 
         RowBox[{"-", "1"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "17", ",", "1", ",", "18", ",", 
         RowBox[{"-", "1"}]}], "}"}], ",", 
