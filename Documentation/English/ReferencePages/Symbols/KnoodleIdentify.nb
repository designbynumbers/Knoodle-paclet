Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"1fe6adfa-be64-42b8-874e-609535afa816"],

Cell["\<\
A knot with more crossings than the lookup table covers comes back as \
Unidentified together with its signed PD code. Here a (2,17) torus knot is \
sampled and tilted into general position:\
\>", "ExampleText",ExpressionUUID->"c1ce0e83-d0aa-457a-8842-d614941a323f"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"torus", "=", 
    RowBox[{"Most", "[", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"N", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"2", " ", "t"}], "]"}], " ", 
           RowBox[{"(", 
            RowBox[{"2", "+", 
             RowBox[{"Cos", "[", 
              RowBox[{"17", " ", "t"}], "]"}]}], ")"}]}], ",", 
          RowBox[{
           RowBox[{"Sin", "[", 
            RowBox[{"2", " ", "t"}], "]"}], " ", 
           RowBox[{"(", 
            RowBox[{"2", "+", 
             RowBox[{"Cos", "[", 
              RowBox[{"17", " ", "t"}], "]"}]}], ")"}]}], ",", 
          RowBox[{"Sin", "[", 
           RowBox[{"17", " ", "t"}], "]"}]}], "}"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0.`", ",", 
         RowBox[{"2", " ", "\[Pi]"}], ",", 
         FractionBox[
          RowBox[{"2", " ", "\[Pi]"}], "680"]}], "}"}]}], "]"}], "]"}]}], 
   ";"}],
  HoldForm]], "Input",ExpressionUUID->"c1428e2a-16ac-49f5-bbeb-d51ac7dd4dde"],

Cell[CellGroupData[{

Cell[BoxData[
 TagBox[
  RowBox[{"KnoodleIdentify", "[", 
   RowBox[{
    RowBox[{"RotationTransform", "[", 
     RowBox[{"0.4`", ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2", ",", "3"}], "}"}]}], "]"}], "/@", "torus"}], 
   "]"}],
  HoldForm]], "Input",ExpressionUUID->"240112e5-3c1e-402d-b47f-c008543cf272"],

