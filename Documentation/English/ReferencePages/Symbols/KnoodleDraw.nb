Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"4a411833-477b-4211-95f9-0dafc27269bf"],

Cell["\<\
Strand thickness scales with the diagram by default, keeping the over/under \
gaps at every crossing visible even on dense diagrams. Here a (2,15) torus \
knot is drawn from a sampled space curve:\
\>", "ExampleText",ExpressionUUID->"4d888fa6-23e6-469d-b029-a42b38579e53"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"torus", "=", 
    RowBox[{"Most", "[", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"N", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"2", " ", "t"}], "]"}], " ", 
           RowBox[{"(", 
            RowBox[{"2", "+", 
             RowBox[{"Cos", "[", 
              RowBox[{"15", " ", "t"}], "]"}]}], ")"}]}], ",", 
          RowBox[{
           RowBox[{"Sin", "[", 
            RowBox[{"2", " ", "t"}], "]"}], " ", 
           RowBox[{"(", 
            RowBox[{"2", "+", 
             RowBox[{"Cos", "[", 
              RowBox[{"15", " ", "t"}], "]"}]}], ")"}]}], ",", 
          RowBox[{"Sin", "[", 
           RowBox[{"15", " ", "t"}], "]"}]}], "}"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0.`", ",", 
         RowBox[{"2", " ", "\[Pi]"}], ",", 
         FractionBox[
          RowBox[{"2", " ", "\[Pi]"}], "600"]}], "}"}]}], "]"}], "]"}]}], 
   ";"}],
  HoldForm]], "Input",ExpressionUUID->"ba887a15-f20b-4e42-ab26-ccd9a124a155"],

