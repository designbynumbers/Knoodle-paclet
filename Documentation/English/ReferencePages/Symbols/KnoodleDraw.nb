    RowBox[{"\"\<Orientation\>\"", "\[Rule]", "True"}], ",", 
    RowBox[{"\"\<Labels\>\"", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\"\<Crossings\>\"", ",", "\"\<Arcs\>\""}], "}"}]}], ",", 
    RowBox[{"ImageSize", "\[Rule]", "280"}]}], "]"}],
  HoldForm]], "Input",ExpressionUUID->"fa68b723-1312-4065-adec-8948ae3422e0"],

