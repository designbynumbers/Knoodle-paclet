Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"5d23bcb3-cbb7-47bf-903a-ed3fca0acdb2"],

Cell["\<\
3D geometry is simplified before drawing by default. Turn \"Simplify\" off to \
draw the raw projection of a Gaussian random 200-gon, with well over a \
hundred crossings:\
\>", "ExampleText",ExpressionUUID->"a738c02d-d389-4c4c-8d2f-80f160c30f73"],

Cell[BoxData[
 RowBox[{
  RowBox[{"GaussianRandomPolygon", "[", "n_", "]"}], " ", ":=", " ", 
  RowBox[{"Accumulate", "[", 
   RowBox[{"Standardize", "[", 
    RowBox[{
     RowBox[{"RandomVariate", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"n", ",", " ", "3"}], "}"}]}], "]"}], ",", " ", "Mean", ",", 
     " ", 
     RowBox[{"1", " ", "&"}]}], " ", "]"}], "]"}]}]], "Input",ExpressionUUID->\
"8138779b-43ee-4eaa-b362-5a533ea1beba"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SeedRandom", "[", "3", "]"}], ";", " ", 
   RowBox[{"P", " ", "=", " ", 
    RowBox[{"GaussianRandomPolygon", "[", "200", "]"}]}], ";"}], 
  " "}]], "Input",ExpressionUUID->"4725c014-09b0-4c2f-a5fb-0573ef9b31c7"],

