Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"b67cbee9-01fa-49c1-afa9-7d27b73839e9"],

Cell["\<\
A 13-crossing knot, drawn by DrawPD (left) and KnoodleDraw (right) from \
KnotInfo's published PD code for 13a_1 (the same pd13a1 as above); \
KnoodleIdentify confirms the knot:\
\>", "ExampleText",ExpressionUUID->"68a9af9a-12e5-4d33-bd97-766f5c0ada2b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"KnoodleIdentify", "[", "pd13a1", "]"}]], "Input",ExpressionUUID->"a3a582c0-0f8f-4b11-9b19-5c135dec9ebc"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   InterpretationBox[
    SubscriptBox["\<\"13a\"\>", "1"],
    Knoodle`KnotSymbol[13, 1, True, "e/r"]], "\[Rule]", "1"}], 
  "\[RightAssociation]"}]], "Output",ExpressionUUID->"292c0e32-4a32-4e11-9f1e-\
4ad071053d3e"]
}, Open  ]],

