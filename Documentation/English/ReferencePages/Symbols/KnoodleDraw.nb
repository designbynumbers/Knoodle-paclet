Cell["", "ExampleDelimiter",ExpressionUUID->"19ecdc8a-4bd0-46d8-8609-a993ca9fbcf8"],

Cell["\<\
LabelStyle styles the label text -- here bold and red on a trefoil PD code. \
The label font size is computed to fit the diagram and is uniform across all \
labels:\
\>", "ExampleText",ExpressionUUID->"8702a292-8800-4f84-92aa-88dba9019f5c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"pd", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "3", ",", " ", "1", ",", " ", "4"}], "}"}], ",",
       " ", 
