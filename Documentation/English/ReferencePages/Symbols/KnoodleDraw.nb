Cell["", "ExampleDelimiter",ExpressionUUID->"9b138c41-6e06-4f57-b2cc-8f100537c173"],

Cell["\<\
A list of point lists is a multi-component link, one closed 3D curve per \
component. Two circles in orthogonal planes form a Hopf link:\
\>", "ExampleText",ExpressionUUID->"54a1df66-01c2-4c16-848c-85e8b7635ddc"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"c1", " ", "=", " ", 
    RowBox[{"Most", "[", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"N", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Cos", "[", "t", "]"}], ",", " ", 
          RowBox[{"Sin", "[", "t", "]"}], ",", " ", "0"}], "}"}], "]"}], ",", 
       " ", 
       RowBox[{"{", 
