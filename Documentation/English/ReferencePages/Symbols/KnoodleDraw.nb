Cell["", "ExampleDelimiter",ExpressionUUID->"dc029a72-256a-418c-ada0-00ed857b91a1"],

Cell["\<\
Draw a Hopf link from its two component curves, with a legend matching each \
component's color to its component number:\
\>", "ExampleText",ExpressionUUID->"38a266e2-fdfb-4cef-8667-e622106d83eb"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"c1", "=", 
    RowBox[{"Most", "[", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"N", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Cos", "[", "t", "]"}], ",", 
          RowBox[{"Sin", "[", "t", "]"}], ",", "0"}], "}"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0.`", ",", 
         RowBox[{"2", " ", "\[Pi]"}], ",", 
         FractionBox[
          RowBox[{"2", " ", "\[Pi]"}], "60"]}], "}"}]}], "]"}], "]"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"2aeb62ca-49b3-4139-82ca-9b84b7f9e125"],

