Cell["\<\
\"ExteriorFace\" chooses which face is laid out as the unbounded exterior \
region; label the faces to see the ids:\
\>", "ExampleText",ExpressionUUID->"61d56f3d-9984-4c5d-bea5-a51f894249e6"],

