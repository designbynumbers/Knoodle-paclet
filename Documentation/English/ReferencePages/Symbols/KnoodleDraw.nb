Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"c392096a-233f-4d28-ad73-2ce8222dd687"],

Cell["\<\
3D geometry is simplified before drawing by default. Turn \"Simplify\" off to \
draw the raw projection of a Gaussian random 200-gon, with well over a \
hundred crossings:\
\>", "ExampleText",ExpressionUUID->"cd95579d-2572-470a-8094-5001e7186409"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"GaussianRandomPolygon", "[", "n_", "]"}], ":=", 
   RowBox[{"Accumulate", "[", 
    RowBox[{"Standardize", "[", 
     RowBox[{
      RowBox[{"RandomVariate", "[", 
       RowBox[{
        RowBox[{"NormalDistribution", "[", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "3"}], "}"}]}], "]"}], ",", "Mean", ",", 
      RowBox[{"1", "&"}]}], "]"}], "]"}]}],
  HoldForm]], "Input",ExpressionUUID->"a91a3e96-8e05-4479-9d25-476a32a01e6a"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"SeedRandom", "[", "3", "]"}], ";", 
   RowBox[{"P", "=", 
    RowBox[{"GaussianRandomPolygon", "[", "200", "]"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"4e9d090f-88ae-40f1-a43e-cac684ab01c0"],

Cell[CellGroupData[{

Cell[BoxData[
