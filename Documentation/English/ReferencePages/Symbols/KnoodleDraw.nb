Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"c823ac0a-9a8d-4679-90b3-b4ac614df239"],

Cell["\<\
KnoodleDraw is more robust than DrawPD. First, it draws diagrams containing \
Reidemeister-I loops: the raw z-axis projection of a Gaussian random 50-gon \
has 21 crossings, three of them kinks, and DrawPD's circle packing does not \
terminate on any diagram containing a monogon. KnoodleDraw draws it exactly \
as projected:\
\>", "ExampleText",ExpressionUUID->"6db03440-727b-454d-8174-8db0c8b992f8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"GaussianRandomPolygon", "[", "n_", "]"}], " ", ":=", " ", 
  RowBox[{"Accumulate", "[", 
   RowBox[{"Standardize", "[", 
    RowBox[{
     RowBox[{"RandomVariate", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"n", ",", " ", "3"}], "}"}]}], "]"}], ",", " ", "Mean", ",", 
     " ", 
     RowBox[{"1", " ", "&"}]}], " ", "]"}], "]"}]}]], "Input",ExpressionUUID->\
"cee9bf8e-7360-4201-ad8e-bcb0a85a48e3"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SeedRandom", "[", "2026", "]"}], ";", " ", 
   RowBox[{"Q", " ", "=", " ", 
    RowBox[{"GaussianRandomPolygon", "[", "50", "]"}]}], ";"}], 
  " "}]], "Input",ExpressionUUID->"ae57d380-8f18-43b1-b743-c310e71c572b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"KnoodleDraw", "[", 
  RowBox[{"Q", ",", " ", 
   RowBox[{"\"\<Simplify\>\"", " ", "->", " ", "False"}], ",", " ", 
   RowBox[{"\"\<RandomizeProjection\>\"", " ", "->", " ", "False"}], ",", " ", 
   RowBox[{"ImageSize", " ", "->", " ", "260"}]}], "]"}]], "Input",ExpressionU\
UID->"8407e79b-700a-4017-bfc5-841a3d94cc71"],

