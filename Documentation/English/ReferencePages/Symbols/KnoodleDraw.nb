        RowBox[{"{", 
         RowBox[{
          RowBox[{"1", "+", 
           RowBox[{"Cos", "[", "t", "]"}]}], ",", "0", ",", 
          RowBox[{"Sin", "[", "t", "]"}]}], "}"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0.`", ",", 
         RowBox[{"2", " ", "\[Pi]"}], ",", 
         FractionBox[
          RowBox[{"2", " ", "\[Pi]"}], "60"]}], "}"}]}], "]"}], "]"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"d4476186-2779-4ff3-a7d4-8a3fd1f86aa4"],

