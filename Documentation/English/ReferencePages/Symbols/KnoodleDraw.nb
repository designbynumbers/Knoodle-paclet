Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"090188e3-75db-4d3c-9b11-ee5aad8d7bb9"],

Cell["\<\
Drawing a multi-summand complex gives a list of Graphics at one common scale, \
and strand colors identify link components across the summands: same color, \
same physical component. The connect sum of a trefoil and a Hopf link \
(colored PD input: trefoil rows on component 0, Hopf rows on components 0 and \
1) splits into two prime factors -- the trefoil factor draws in component 0's \
color, the same color as the Hopf strand it is tied into:\
\>", "ExampleText",ExpressionUUID->"d5cbf6f4-e296-4480-ba11-f9b975a3e672"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"trefC", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "0", ",", " ", "3", ",", " ", "1", ",", " ", "4", ",", " ", "0", ",", 
        " ", "0"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
       "2", ",", " ", "5", ",", " ", "3", ",", " ", "0", ",", " ", "0", ",", 
        " ", "0"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
       "4", ",", " ", "1", ",", " ", "5", ",", " ", "2", ",", " ", "0", ",", 
        " ", "0"}], "}"}]}], "}"}]}], ";"}], " "}]], "Input",ExpressionUUID->\
"bb0decc4-0014-482b-80e7-c74600fb754d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"hopfC", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "3", ",", " ", "0", ",", " ", "2", ",", " ", "1", ",", " ", "1", ",", 
        " ", "0"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
       "1", ",", " ", "2", ",", " ", "0", ",", " ", "3", ",", " ", "0", ",", 
        " ", "1"}], "}"}]}], "}"}]}], ";"}], " "}]], "Input",ExpressionUUID->\
"40ebe0ec-ffbb-4202-973d-ff838429f3f8"],

