Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"20a36355-d88d-4fac-8fb1-b73ef780e88d"],

Cell["\<\
Strand thickness scales with the diagram by default, keeping the over/under \
gaps at every crossing visible even on dense diagrams. Here a (2,15) torus \
knot is drawn from a sampled space curve:\
\>", "ExampleText",ExpressionUUID->"dada4284-f273-4f82-b3a0-c547fafabdca"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"torus", "=", 
    RowBox[{"Most", "[", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"N", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"2", " ", "t"}], "]"}], " ", 
           RowBox[{"(", 
            RowBox[{"2", "+", 
             RowBox[{"Cos", "[", 
              RowBox[{"15", " ", "t"}], "]"}]}], ")"}]}], ",", 
          RowBox[{
           RowBox[{"Sin", "[", 
            RowBox[{"2", " ", "t"}], "]"}], " ", 
           RowBox[{"(", 
            RowBox[{"2", "+", 
             RowBox[{"Cos", "[", 
              RowBox[{"15", " ", "t"}], "]"}]}], ")"}]}], ",", 
          RowBox[{"Sin", "[", 
           RowBox[{"15", " ", "t"}], "]"}]}], "}"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0.`", ",", 
         RowBox[{"2", " ", "\[Pi]"}], ",", 
         FractionBox[
          RowBox[{"2", " ", "\[Pi]"}], "600"]}], "}"}]}], "]"}], "]"}]}], 
   ";"}],
  HoldForm]], "Input",ExpressionUUID->"dc45a37b-6e46-4a96-a491-2654c1a6d1aa"],

