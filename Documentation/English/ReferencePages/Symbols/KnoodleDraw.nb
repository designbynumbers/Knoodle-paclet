Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"31d8b903-438f-4d63-8bc8-4ef2b128b273"],

Cell["\<\
3D geometry is simplified before drawing by default. Turn \"Simplify\" off to \
draw the raw projection of a Gaussian random 200-gon, with well over a \
hundred crossings:\
\>", "ExampleText",ExpressionUUID->"1d878c0a-8a11-498f-96dd-85c345f58824"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"GaussianRandomPolygon", "[", "n_", "]"}], ":=", 
   RowBox[{"Accumulate", "[", 
    RowBox[{"Standardize", "[", 
     RowBox[{
      RowBox[{"RandomVariate", "[", 
       RowBox[{
        RowBox[{"NormalDistribution", "[", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "3"}], "}"}]}], "]"}], ",", "Mean", ",", 
      RowBox[{"1", "&"}]}], "]"}], "]"}]}],
  HoldForm]], "Input",ExpressionUUID->"602c67cd-7a45-4a7b-a2d7-2822696e0b3c"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"SeedRandom", "[", "3", "]"}], ";", 
   RowBox[{"P", "=", 
    RowBox[{"GaussianRandomPolygon", "[", "200", "]"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"f386fd08-bb09-47ed-a365-691913a95a0d"],

Cell[CellGroupData[{

