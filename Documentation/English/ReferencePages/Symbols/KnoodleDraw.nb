Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"c771342f-8dc3-496c-a90c-02c50a58c780"],

Cell["\<\
\"CornerRadius\" runs from 0 (sharp corners) to 1/2 (maximally rounded), here \
on a trefoil PD code:\
\>", "ExampleText",ExpressionUUID->"d0a6a2f1-116f-4949-9522-1cbc355d2752"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"pd", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", "3", ",", "1", ",", "4"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"2", ",", "5", ",", "3", ",", "0"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"4", ",", "1", ",", "5", ",", "2"}], "}"}]}], "}"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"53c2518f-e0c6-4e25-b9f0-332295871b70"],

