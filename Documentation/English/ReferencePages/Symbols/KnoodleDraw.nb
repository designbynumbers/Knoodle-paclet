 TagBox[
  RowBox[{"KnoodleDraw", "[", 
   RowBox[{"pd52", ",", 
    RowBox[{"\"\<Orientation\>\"", "\[Rule]", "True"}], ",", 
    RowBox[{"\"\<Labels\>\"", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\"\<Crossings\>\"", ",", "\"\<Arcs\>\""}], "}"}]}], ",", 
    RowBox[{"ImageSize", "\[Rule]", "280"}]}], "]"}],
  HoldForm]], "Input",ExpressionUUID->"d90eb76e-64ff-48f5-90cb-d9b674cc4aeb"],

