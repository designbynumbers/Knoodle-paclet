      RowBox[{"pd", ",", 
        RowBox[{"\"Labels\"", "\[Rule]", "\"Faces\""}], ",", 
        RowBox[{"ImageSize", "\[Rule]", "160"}]}], "]"}], 
    RowBox[{"KnoodleDraw", "[", 
      RowBox[{"pd", ",", 
