Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"f1480170-aa12-45be-a9d7-824d5a819a3d"],

Cell["\<\
A PD code determines the diagram but not the drawing: \"LayoutOptions\" \
forwards layout flags to the knoodledraw tool, and different compaction or \
bend choices give very different orthogonal drawings of the same code. Here \
the 13-crossing knot 13a_1 (PD code from KnotInfo, 0-based) with the default \
layout, with \"compaction\" -> \"topo-order\", and with four rounds of bend \
randomization:\
\>", "ExampleText",ExpressionUUID->"5a969093-d753-422e-88e7-dbdb30eed653"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"pd13a1", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"2", ",", " ", "0", ",", " ", "3", ",", " ", "25"}], "}"}], ",",
       " ", 
