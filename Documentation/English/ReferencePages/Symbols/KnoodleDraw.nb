Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"f61f29e6-58d2-41d7-9d56-9cbc716172f9"],

Cell["\<\
Strand thickness scales with the diagram by default, keeping the over/under \
gaps at every crossing visible even on dense diagrams. Here a (2,15) torus \
knot is drawn from a sampled space curve:\
\>", "ExampleText",ExpressionUUID->"d8c2988a-4047-4b5b-a510-994cbe7b4b78"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"torus", "=", 
    RowBox[{"Most", "[", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"N", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"2", " ", "t"}], "]"}], " ", 
           RowBox[{"(", 
            RowBox[{"2", "+", 
             RowBox[{"Cos", "[", 
              RowBox[{"15", " ", "t"}], "]"}]}], ")"}]}], ",", 
          RowBox[{
           RowBox[{"Sin", "[", 
            RowBox[{"2", " ", "t"}], "]"}], " ", 
           RowBox[{"(", 
            RowBox[{"2", "+", 
             RowBox[{"Cos", "[", 
              RowBox[{"15", " ", "t"}], "]"}]}], ")"}]}], ",", 
          RowBox[{"Sin", "[", 
           RowBox[{"15", " ", "t"}], "]"}]}], "}"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0.`", ",", 
         RowBox[{"2", " ", "\[Pi]"}], ",", 
         FractionBox[
          RowBox[{"2", " ", "\[Pi]"}], "600"]}], "}"}]}], "]"}], "]"}]}], 
   ";"}],
  HoldForm]], "Input",ExpressionUUID->"69fc6180-4827-438b-8680-cf632bb7886a"],

