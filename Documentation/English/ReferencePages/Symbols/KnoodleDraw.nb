Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"4d03ddea-079b-4538-9fc6-93379cfe5e11"],

Cell["\<\
KnotTheory`'s DrawPD function (katlas.org/wiki/Drawing_Planar_Diagrams) also \
draws diagrams directly from PD codes. The comparisons below show DrawPD's \
output from drawings bundled with this paclet, so they display even without \
KnotTheory` installed. First, the 10-crossing \"Millett unknot\" -- the \
worked example on DrawPD's own manual page -- drawn by DrawPD (left, with the \
page's recommended Gap -> 0.03) and by KnoodleDraw (right, from the same PD \
code, 0-based):\
\>", "ExampleText",ExpressionUUID->"631870f6-9370-4f87-90cb-82336316c49e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"gallery", " ", "=", " ", 
    RowBox[{
     RowBox[{"PacletObject", "[", "\"\<Knoodle\>\"", "]"}], "[", 
     RowBox[{"\"\<AssetLocation\>\"", ",", " ", "\"\<DrawPDGallery\>\""}], 
     "]"}]}], ";"}], " "}]], "Input",ExpressionUUID->"0051e9e7-efff-4e77-8a99-\
1dc6ede4faaa"],

