Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"b89638a3-b086-4d08-9f38-509ee0e0e916"],

Cell["\<\
For users who do have KnotTheory` installed, KnoodleDraw is a drop-in \
replacement for DrawPD: it accepts KnotTheory's PD[X[...], ...] objects (and \
DTCode/GaussCode) directly, in KnotTheory's own 1-based arc numbering. The \
Millett unknot again, exactly as written on the DrawPD manual page:\
\>", "ExampleText",ExpressionUUID->"9097363e-4677-40b0-9cbf-9b70545a1f8a"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<KnotTheory`\>\"", "]"}]], "Input",ExpressionUUID->"688a5ebe-1407-41b5-abb5-4ad0fec3ce95"],

