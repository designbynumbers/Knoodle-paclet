Cell["", "ExampleDelimiter",ExpressionUUID->"d8faeb67-66f1-466e-b3cf-9ba7384cfd39"],

Cell["\<\
\"CornerRadius\" runs from 0 (sharp corners) to 1/2 (maximally rounded), here \
on a trefoil PD code:\
\>", "ExampleText",ExpressionUUID->"a4e4c2fc-820d-486f-8e8e-e4dcfae560f7"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"pd", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", "3", ",", "1", ",", "4"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"2", ",", "5", ",", "3", ",", "0"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"4", ",", "1", ",", "5", ",", "2"}], "}"}]}], "}"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"13350896-6a25-4da6-8ca9-561813993ad9"],

