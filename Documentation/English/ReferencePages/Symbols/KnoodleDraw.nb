 TagBox[
  RowBox[{
   RowBox[{"pd", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", "3", ",", "1", ",", "4"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"2", ",", "5", ",", "3", ",", "0"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"4", ",", "1", ",", "5", ",", "2"}], "}"}]}], "}"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"224163fb-93ea-4dc7-acca-999d506061f2"],

