Cell[CellGroupData[{

Cell["KnoodleDraw", "ObjectName",ExpressionUUID->"f51d4434-3b33-48c8-ba4c-79e8ceb9aeac"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"f94ee034-4616-48dc-af2a-cc46f98d7c76"],
 Cell[BoxData[
  RowBox[{"KnoodleDraw", "[", 
   StyleBox["input", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "10bc1305-19f6-40ee-a84f-2c8671f098c6"],
 "\[LineSeparator]draws a picture of a knot or link diagram, returning a \
Graphics object."
}], "Usage",ExpressionUUID->"ade356c6-c37f-4eac-b299-9a7ec6260e92"],

Cell["\<\
input may be a KnotData specification (e.g. Knot[3,1], {3,1}, or \
\"Trefoil\"), a PD/DTCode/GaussCode from the KnotTheory package, a Function \
(sampled as a closed space curve for t from 0 to 2 Pi), a list of 3D points \
(one closed space curve), a list of point lists (a multi-component link), a \
native Knoodle PD code, or a PlanarDiagramComplex from KnoodleSimplify.\
\>", "Notes",ExpressionUUID->"2613919f-305b-4fc0-ab0e-7408d160050a"],

Cell["\<\
A native Knoodle PD code is a list of crossing rows of 4 to 7 integers each: \
4 columns give an unsigned PD code, a 5th column gives the crossing \
handedness (\[PlusMinus]1), and two further columns carry the incoming \
under-/over-arc component colors that keep link components identified through \
simplification. A list of such row lists denotes a connect sum or split link, \
one summand each; the empty summand {} is an unknot, so {{}} draws the \
standalone unknot.\
\>", "Notes",ExpressionUUID->"afb36913-0917-4c78-9ff5-96ad24d0900c"],

Cell["\<\
3D geometry and KnotData inputs are simplified before drawing by default; \
explicit diagram inputs (PD codes, KnotTheory objects, PlanarDiagramComplex) \
are drawn exactly as given unless \"Simplify\" -> True is set.\
\>", "Notes",ExpressionUUID->"967591f3-c01a-45b3-8561-c7df507dbbf1"],

Cell["\<\
KnoodleDraw returns Graphics, or Legended[Graphics, \[Ellipsis]] when \
PlotLegends -> Automatic is given. Unrecognized input yields $Failed with a \
KnoodleDraw::badinput message.\
\>", "Notes",ExpressionUUID->"eb94f637-581c-4cc0-a096-02168d6a079e"],

Cell["The following options can be given:", "Notes",ExpressionUUID->"72ddb7f4-a455-4f47-aaf9-a6a207e84660"],

Cell[BoxData[GridBox[{
   {Cell["      ", "ModInfo",ExpressionUUID->
     "c58c55fd-b31f-43c0-ad9b-bf992a6bb7f3"], "\"\<Simplify\>\"", "Automatic",
     Cell["\<\
whether to simplify the diagram before drawing; Automatic simplifies \
geometry/KnotData input but draws explicit diagram input as-is\
\>", "TableText",ExpressionUUID->"40f05d72-0723-4f38-aab2-9c2d01247d7f"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "a8188244-11d3-4b64-a0c9-5ad58c20aa7e"], "\"\<CornerRadius\>\"", 
    FractionBox["1", "3"], Cell["\<\
corner-arc radius as a fraction of one grid square, 0 (sharp) to 1/2\
\>", "TableText",ExpressionUUID->"a8c2d50a-c1b6-4bab-a138-833ab07177a0"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "dc5566bc-d133-4577-b95c-cd14bf15ab2f"], "\"\<Thickness\>\"", 
    "Automatic", Cell["\<\
strand thickness: Automatic scales with the diagram so crossing gaps stay \
visible (capped at 7 pt); a number is a fixed AbsoluteThickness; any other \
directive is used as-is\
\>", "TableText",ExpressionUUID->"eb90b626-c6c0-4975-9615-2fdce4d812bd"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "7bb7d47f-272c-42d1-b6c2-abef51204e5b"], "\"\<Checkerboard\>\"", "False",
     Cell["shade the diagram's two-colorable faces", "TableText",
     ExpressionUUID->"d0bb9252-6ca0-4d81-af92-71bef6ce10e6"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "7832e2d5-6a54-46d1-8c4a-aa2f4644d8d7"], "\"\<Orientation\>\"", "False", 
    Cell["\<\
True marks each link component's orientation with an arrowhead on its longest \
arc; All marks every arc. Heads sit mid-run, clear of crossings and labels, \
and scale with the strand thickness\
\>", "TableText",ExpressionUUID->"b6a854e4-52ae-4bdf-9c2c-82ed8cfb3615"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "1b94dc40-cac2-4b9e-a838-c247e9ae4fb0"], "\"\<Labels\>\"", 
    RowBox[{"{", "}"}], Cell["\<\
annotate 0-based element ids: a subset of {\"Crossings\", \"Arcs\", \"Faces\"}\
\>", "TableText",ExpressionUUID->"fe113b88-45d3-421a-bd33-8d82821da737"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "78e8b1d4-0cbc-4565-b348-ea80973d5f99"], "\"\<ExteriorFace\>\"", 
    "Automatic", Cell["\<\
which face (0-based id) to lay out as the unbounded exterior region\
\>", "TableText",ExpressionUUID->"f66a8b3d-fc8b-41fa-950f-866229bf6a2a"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "29c86cf2-7bfd-4714-b944-218a1d62562c"], "PlotLegends", "None", 
    Cell["\<\
Automatic adds a LineLegend matching component colors to component numbers\
\>", "TableText",ExpressionUUID->"56209b56-789d-4260-a307-99bf66f01e40"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "64b6eaf3-197f-4dec-a193-2229a51beeec"], "\"\<RandomizeProjection\>\"", 
    "True", Cell["\<\
randomly rotate 3D input before projecting, avoiding degenerate projections; \
set False for reproducibility\
\>", "TableText",ExpressionUUID->"0e94fa6a-78f3-4ffd-8f0d-352a9a1eba41"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "7c27f112-2bea-4d89-8c2e-5a657f56de67"], "\"\<LayoutOptions\>\"", 
    RowBox[{"{", "}"}], Cell["\<\
extra knoodledraw layout flags, e.g. {\"randomize-bends\" -> 3}; see \
knoodledraw --help\
\>", "TableText",ExpressionUUID->"87182bea-3da5-4ab1-903b-fac48709ad9e"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "847c862b-8ff6-4823-a9de-2f954c14b9bf"], "ImageSize", "340", Cell[
    "size of the resulting Graphics", "TableText",ExpressionUUID->
     "66f2bd37-eb67-42bf-81d5-9f1cc3c8500f"]}
  }]], "3ColumnTableMod",ExpressionUUID->"c8862c3c-bd98-4fde-93d9-\
535f406a06d0"]
}, Open  ]],

