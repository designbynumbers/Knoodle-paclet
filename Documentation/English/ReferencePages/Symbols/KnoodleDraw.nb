Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"a7f86d20-c097-4f4a-86cc-260a10950b83"],

Cell["\<\
A list of point lists is a multi-component link, one closed 3D curve per \
component. Two circles in orthogonal planes form a Hopf link:\
\>", "ExampleText",ExpressionUUID->"474927c0-3700-4dec-9527-629155f6adf2"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"c1", "=", 
    RowBox[{"Most", "[", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"N", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Cos", "[", "t", "]"}], ",", 
          RowBox[{"Sin", "[", "t", "]"}], ",", "0"}], "}"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0.`", ",", 
         RowBox[{"2", " ", "\[Pi]"}], ",", 
         FractionBox[
          RowBox[{"2", " ", "\[Pi]"}], "60"]}], "}"}]}], "]"}], "]"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"7934c0ff-6dca-45b9-8ca5-a894c9b18579"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"c2", "=", 
    RowBox[{"Most", "[", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"N", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"1", "+", 
           RowBox[{"Cos", "[", "t", "]"}]}], ",", "0", ",", 
          RowBox[{"Sin", "[", "t", "]"}]}], "}"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0.`", ",", 
         RowBox[{"2", " ", "\[Pi]"}], ",", 
         FractionBox[
          RowBox[{"2", " ", "\[Pi]"}], "60"]}], "}"}]}], "]"}], "]"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"4abe5ace-4e0a-4592-b672-2a826cc4d117"],

Cell[CellGroupData[{

