Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"a1af0c6e-bfa0-4f57-bc84-f2d7721a6945"],

Cell["\<\
Strand thickness scales with the diagram by default, keeping the over/under \
gaps at every crossing visible even on dense diagrams. Here a (2,15) torus \
knot is drawn from a sampled space curve:\
\>", "ExampleText",ExpressionUUID->"99b96bfd-b5b9-4298-aa3d-2959d0fb32bc"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"torus", " ", "=", " ", 
    RowBox[{"Most", "[", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"N", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"2", "*", "t"}], "]"}], "*", 
           RowBox[{"(", 
            RowBox[{"2", " ", "+", " ", 
             RowBox[{"Cos", "[", 
              RowBox[{"15", "*", "t"}], "]"}]}], ")"}]}], ",", " ", 
          RowBox[{
           RowBox[{"Sin", "[", 
            RowBox[{"2", "*", "t"}], "]"}], "*", 
           RowBox[{"(", 
            RowBox[{"2", " ", "+", " ", 
             RowBox[{"Cos", "[", 
              RowBox[{"15", "*", "t"}], "]"}]}], ")"}]}], ",", " ", 
          RowBox[{"Sin", "[", 
           RowBox[{"15", "*", "t"}], "]"}]}], "}"}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"t", ",", " ", "0.", ",", " ", 
         RowBox[{"2", "*", "Pi"}], ",", " ", 
         RowBox[{"2", "*", 
          RowBox[{"(", 
           RowBox[{"Pi", "/", "600"}], ")"}]}]}], "}"}]}], "]"}], "]"}]}], 
   ";"}], " "}]], "Input",ExpressionUUID->"dc58f663-eea0-4ec0-99bf-\
7a8b446d2849"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"KnoodleDraw", "[", "torus", "]"}]], "Input",ExpressionUUID->"63d803e6-d38f-4cc1-a8ad-615042f18c67"],

