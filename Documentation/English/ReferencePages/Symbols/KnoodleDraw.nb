Cell["\<\
Draw a Hopf link from its two component curves, with a legend matching each \
component's color to its component number:\
\>", "ExampleText",ExpressionUUID->"8578104c-2f2c-4c0a-8525-b25f54f005da"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"c1", "=", 
    RowBox[{"Most", "[", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"N", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Cos", "[", "t", "]"}], ",", 
          RowBox[{"Sin", "[", "t", "]"}], ",", "0"}], "}"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0.`", ",", 
         RowBox[{"2", " ", "\[Pi]"}], ",", 
         FractionBox[
          RowBox[{"2", " ", "\[Pi]"}], "60"]}], "}"}]}], "]"}], "]"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"b5f0ac6a-418a-481b-90f7-151b16f433e4"],

