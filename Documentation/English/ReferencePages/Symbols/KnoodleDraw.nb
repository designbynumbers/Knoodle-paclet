Cell[CellGroupData[{

Cell["", "ExampleDelimiter",ExpressionUUID->"16aa5f25-4435-4c6c-a1e6-e83e9963ef88"],

Cell["\<\
3D geometry is simplified before drawing by default. Turn \"Simplify\" off to \
draw the raw projection of a Gaussian random 200-gon, with well over a \
hundred crossings:\
\>", "ExampleText",ExpressionUUID->"5d26448f-95df-40ba-b0d6-a2fc5f953612"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"GaussianRandomPolygon", "[", "n_", "]"}], ":=", 
   RowBox[{"Accumulate", "[", 
    RowBox[{"Standardize", "[", 
     RowBox[{
      RowBox[{"RandomVariate", "[", 
       RowBox[{
        RowBox[{"NormalDistribution", "[", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "3"}], "}"}]}], "]"}], ",", "Mean", ",", 
      RowBox[{"1", "&"}]}], "]"}], "]"}]}],
  HoldForm]], "Input",ExpressionUUID->"72a2a101-78d8-47d2-aada-fc11f9c72d7d"],

Cell[BoxData[
 TagBox[
  RowBox[{
   RowBox[{"SeedRandom", "[", "3", "]"}], ";", 
   RowBox[{"P", "=", 
    RowBox[{"GaussianRandomPolygon", "[", "200", "]"}]}], ";"}],
  HoldForm]], "Input",ExpressionUUID->"ca929158-c8d5-4641-b634-f65fda48594c"],

