Notebook[{
Cell["KnoodleIdentify", "Title",ExpressionUUID->"8d8284f8-6fa1-494b-a72e-471b7e310945"],

Cell[TextData[{
 Cell[BoxData[Cell["KnoodleIdentify[input]",
   Background->None,ExpressionUUID->"6dd58d0d-41f9-42d4-8db2-70f977517ee6"]], 
  "InlineCode",ExpressionUUID->"168e7a77-5fc8-4aa1-b4df-95e8a70ce70e"],
 " identifies a knot: it looks up the diagram in a table of named knots and \
tells you which one it is."
}], "Text",ExpressionUUID->"3ad46c76-056b-4724-87ca-1184dabee43a"],

Cell[TextData[{
 "If the diagram is a connect sum of several simpler knots -- like the granny \
knot, which is two trefoils tied end to end -- ",
 Cell[BoxData[Cell["KnoodleIdentify",
   Background->None,ExpressionUUID->"498f7a73-0464-445d-9388-8cc09768961e"]], 
  "InlineCode",ExpressionUUID->"10395a51-5bd1-41b4-9208-41266fac34da"],
 " reports each of the simpler pieces and how many times it occurs. "
}], "Text",ExpressionUUID->"81008942-f2e3-4956-8e67-c0386bfa9ced"],

Cell["Calling Convention", "Section",ExpressionUUID->"b050604d-091e-48b8-babb-7ffca4cedd37"],

Cell["KnoodleIdentify[input]", "Program",ExpressionUUID->"8900f711-1269-4124-9b0e-be9a09490b45"],

Cell[TextData[{
 "returns an ",
 Cell[BoxData[
  TemplateBox[{
   "Association", "paclet:ref/Association", 
    "https://reference.wolfram.com/language/ref/Association.html"},
   "TextRefLink",
   DisplayFunction->(TagBox[
     ButtonBox[
      StyleBox[#, ShowStringCharacters -> True, FontFamily -> 
       "Source Sans Pro"], 
      BaseStyle -> {"Link", FontColor -> LightDarkSwitched[
          RGBColor[0.02, 0.286, 0.651], 
          RGBColor[0.2823, 0.6666, 0.949]]}, ButtonData -> #2, ContentPadding -> 
      False], 
     MouseAppearanceTag["LinkHand"]]& )]],ExpressionUUID->
  "2bf6c560-e646-41e5-990b-552e836fe565"],
 " from each identified knot summand (a ",
 Cell[BoxData[Cell["KnotSymbol[...]",
   Background->None,ExpressionUUID->"ca5cbb32-77c2-4c58-8693-2cca96cc580c"]], 
  "InlineCode",ExpressionUUID->"2a02f21a-a6b6-4184-adc9-f8643d32e5f1"],
 ", which displays in ordinary knot-table notation such as ",
 Cell[BoxData[Cell["3_1",
   Background->None,ExpressionUUID->"0fc1baaf-a9e9-4bab-b9b2-848783acb110"]], 
  "InlineCode",ExpressionUUID->"c8cd9e73-2f94-4050-892f-115e68494426"],
 ") to its multiplicity. An unknot summand is the identity for connect sum \
and does not appear, so the unknot itself gives ",
 Cell[BoxData[Cell["<||>",
   Background->None,ExpressionUUID->"e2c66de6-0c89-49ee-9300-5a3174b46cf1"]], 
  "InlineCode",ExpressionUUID->"db6c1189-f795-4477-b042-36416c078194"],
 ", the empty association. ",
 Cell[BoxData[Cell["KnoodleIdentify",
   Background->None,ExpressionUUID->"0114b672-1134-4379-bb92-41972a797e18"]], 
  "InlineCode",ExpressionUUID->"4758190c-d6da-4887-9243-3d9f884d563c"],
 " only identifies knots. If given a genuine link (more than one component), \
it fails with a message; use ",
 Cell[BoxData[Cell["KnoodleSimplify",
   Background->None,ExpressionUUID->"ecbd49cc-2fce-4259-87b5-de7f5c5ab54c"]], 
  "InlineCode",ExpressionUUID->"a338fda6-65c9-47f6-bb92-b8313133674f"],
 " with ",
 Cell[BoxData[Cell["\"Unite\" -> True",
   Background->None,ExpressionUUID->"982403aa-764a-4d7e-951f-7a33b3625cde"]], 
  "InlineCode",ExpressionUUID->"106b6602-1d3c-4deb-9d5a-9279f5c1f05e"],
 " first if the components should be treated as connect-summed into a single \
knot. "
}], "Text",ExpressionUUID->"87559678-1763-4735-8a04-a86491f18283"],

Cell["Input Formats", "Section",ExpressionUUID->"21f92be6-3106-45b0-a86c-c23c3081832b"],

Cell[TextData[{
 StyleBox["input", "TI"],
 " accepts the same representations as ",
 Cell[BoxData[Cell["KnoodleDraw",
   Background->None,ExpressionUUID->"ffdde154-33b8-46d7-b713-91a65ea839ff"]], 
  "InlineCode",ExpressionUUID->"a1571648-8abb-42ee-a761-fee618cb9d27"],
 ": a ",
 Cell[BoxData[
  TemplateBox[{
   "KnotData", "paclet:ref/KnotData", 
    "https://reference.wolfram.com/language/ref/KnotData.html"},
   "TextRefLink",
   DisplayFunction->(TagBox[
     ButtonBox[
      StyleBox[#, ShowStringCharacters -> True, FontFamily -> 
       "Source Sans Pro"], 
      BaseStyle -> {"Link", FontColor -> LightDarkSwitched[
          RGBColor[0.02, 0.286, 0.651], 
          RGBColor[0.2823, 0.6666, 0.949]]}, ButtonData -> #2, ContentPadding -> 
      False], 
     MouseAppearanceTag["LinkHand"]]& )]],ExpressionUUID->
  "894db7ff-1eea-43d3-850f-d52eebd87519"],
 " specification, a PD code / DTCode / GaussCode from the KnotTheory package, \
a 3D space curve, a native Knoodle PD code, or a ",
 Cell[BoxData[Cell["PlanarDiagramComplex",
   Background->None,ExpressionUUID->"5d69e963-4ff1-45cb-8f12-adac8931588c"]], 
  "InlineCode",ExpressionUUID->"22b5792d-60c7-4529-b7be-02b1a6919f53"],
 " from ",
 Cell[BoxData[Cell["KnoodleSimplify",
   Background->None,ExpressionUUID->"c7346790-3a50-4ead-b2cc-deb6531f9fee"]], 
  "InlineCode",ExpressionUUID->"36c85b34-0d5b-4979-b139-58f9da3111ab"],
 ". "
}], "Text",ExpressionUUID->"7a0abcf4-6515-4e8e-a72d-8881f88d913b"],

Cell["Examples", "Section",ExpressionUUID->"14c3760e-06c1-4468-a209-5b2692b737d0"],

Cell["KnoodleIdentify[Knot[3, 1]]", "Program",ExpressionUUID->"58938479-6964-4c52-8eab-9b762235ac49"],

Cell[TextData[{
 "gives ",
 Cell[BoxData[Cell["<|KnotSymbol[3, 1, True, \"m/mr\"] -> 1|>",
   Background->None,ExpressionUUID->"082d8d1b-6a26-4762-a63e-d1e877c02909"]], 
  "InlineCode",ExpressionUUID->"6cb757ab-cd1f-4f69-b6b6-9cf4d656f61c"],
 "."
}], "Text",ExpressionUUID->"0e2b6229-d0bf-4867-9d03-f1b4e184ef0e"]
},
