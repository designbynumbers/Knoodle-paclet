   Background->None,ExpressionUUID->"2b8486e9-9fb1-4c04-9d27-4b5612ed4e0d"]], 
  "InlineCode",ExpressionUUID->"31d6d668-96d0-4fe5-8513-801f871289f4"],
 "."
}], "Item",ExpressionUUID->"f07817d2-5ba8-436b-bec0-90678192d19c"],

Cell["Examples", "Section",ExpressionUUID->"eee2db5a-80b0-463f-bfa5-9b2a8977d4a0"],

Cell["Draw the trefoil knot: ", "Text",ExpressionUUID->"de38cc92-706f-4749-b266-ae35e099955f"],

