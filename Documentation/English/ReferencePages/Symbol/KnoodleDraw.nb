Notebook[{
Cell["KnoodleDraw", "Title",ExpressionUUID->"9c5e2f05-bddd-4327-be7f-80ab9e55cc6b"],

Cell[TextData[{
 Cell[BoxData[Cell["KnoodleDraw[input]",
   Background->None,ExpressionUUID->"40a12d68-6f79-4317-9775-cb36b9bda180"]], 
  "InlineCode",ExpressionUUID->"40abf2c4-0626-4e58-b77d-dc080fb0aef5"],
 " draws a picture of a knot or link diagram."
}], "Text",ExpressionUUID->"2343622e-3e47-4dfb-9761-3eab53f73f57"],

Cell[TextData[{
 "Give it a description of a knot or link, in any of several convenient \
formats, and it returns a ",
 Cell[BoxData[
  TemplateBox[{
   "Graphics", "paclet:ref/Graphics", 
    "https://reference.wolfram.com/language/ref/Graphics.html"},
   "TextRefLink",
   DisplayFunction->(TagBox[
     ButtonBox[
      StyleBox[#, ShowStringCharacters -> True, FontFamily -> 
       "Source Sans Pro"], 
      BaseStyle -> {"Link", FontColor -> LightDarkSwitched[
          RGBColor[0.02, 0.286, 0.651], 
          RGBColor[0.2823, 0.6666, 0.949]]}, ButtonData -> #2, ContentPadding -> 
      False], 
     MouseAppearanceTag["LinkHand"]]& )]],ExpressionUUID->
  "9495dc69-e9ae-46e0-abbf-fb259249c935"],
 " object showing the diagram, with crossings drawn in the usual over/under \
style. "
}], "Text",ExpressionUUID->"61c69c2d-c882-42ac-aeca-c7ec4f245f2e"],

Cell["Calling Convention", "Section",ExpressionUUID->"76b3e5bc-fe52-4311-b242-31730ae7f500"],

Cell["KnoodleDraw[input]", "Program",ExpressionUUID->"61c97e02-c4fe-4177-9da0-89d1cd6a3baa"],

Cell[TextData[{
 "returns a ",
 Cell[BoxData[
  TemplateBox[{
   "Graphics", "paclet:ref/Graphics", 
    "https://reference.wolfram.com/language/ref/Graphics.html"},
   "TextRefLink",
   DisplayFunction->(TagBox[
     ButtonBox[
      StyleBox[#, ShowStringCharacters -> True, FontFamily -> 
       "Source Sans Pro"], 
      BaseStyle -> {"Link", FontColor -> LightDarkSwitched[
          RGBColor[0.02, 0.286, 0.651], 
          RGBColor[0.2823, 0.6666, 0.949]]}, ButtonData -> #2, ContentPadding -> 
      False], 
     MouseAppearanceTag["LinkHand"]]& )]],ExpressionUUID->
  "0082145a-76cc-4a98-9d25-8d95f2cc0593"],
 " object. Options can be given in the usual way, e.g. ",
 Cell[BoxData[Cell["KnoodleDraw[input, \"Checkerboard\" -> True]",
   Background->None,ExpressionUUID->"075b0fdf-f9c3-4ce1-ac50-b0825790a55a"]], 
  "InlineCode",ExpressionUUID->"9147a80e-a03c-454a-9915-b0846311b22a"],
 ". "
}], "Text",ExpressionUUID->"2fdabaec-ce7d-4e77-9062-1a9ecd6cd318"],

Cell["Input Formats", "Section",ExpressionUUID->"3f446cd1-9e3f-4c80-a2d3-3e3c40285682"],

Cell[TextData[{
 StyleBox["input", "TI"],
 " may be any of the following: "
}], "Text",ExpressionUUID->"600610f6-7096-4da7-bf38-52f6e851c298"],

Cell[TextData[{
 "A ",
 Cell[BoxData[
  TemplateBox[{
   "KnotData", "paclet:ref/KnotData", 
    "https://reference.wolfram.com/language/ref/KnotData.html"},
   "TextRefLink",
   DisplayFunction->(TagBox[
     ButtonBox[
      StyleBox[#, ShowStringCharacters -> True, FontFamily -> 
       "Source Sans Pro"], 
      BaseStyle -> {"Link", FontColor -> LightDarkSwitched[
          RGBColor[0.02, 0.286, 0.651], 
          RGBColor[0.2823, 0.6666, 0.949]]}, ButtonData -> #2, ContentPadding -> 
      False], 
     MouseAppearanceTag["LinkHand"]]& )]],ExpressionUUID->
  "e0b3c163-21da-465a-bfca-12a58a95ad53"],
 "-style specification, e.g. ",
 Cell[BoxData[Cell["Knot[3, 1]",
   Background->None,ExpressionUUID->"c0680f22-dd89-4ac1-aaf4-d7eeacabcdb9"]], 
  "InlineCode",ExpressionUUID->"c9cdfece-e037-4245-8e40-b5a8e571819a"],
 ", ",
 Cell[BoxData[Cell["{3, 1}",
   Background->None,ExpressionUUID->"09cd37b2-a5b9-4b9f-b3f9-1630b78550db"]], 
  "InlineCode",ExpressionUUID->"e057822b-7237-424e-b203-2b3449d4de06"],
 ", or ",
 Cell[BoxData["\"\<Trefoil\>\""], "InlineWL", "Input",
  ShowAutoStyles->True,
  ShowSyntaxStyles->True,
  LanguageCategory->"Input",
  ShowStringCharacters->True,ExpressionUUID->
  "ddb9b4e7-992c-4f0d-b1fa-a63c1db943cc"],
 " -- anything ",
 Cell[BoxData[
  TemplateBox[{
   "KnotData", "paclet:ref/KnotData", 
    "https://reference.wolfram.com/language/ref/KnotData.html"},
   "TextRefLink",
   DisplayFunction->(TagBox[
     ButtonBox[
      StyleBox[#, ShowStringCharacters -> True, FontFamily -> 
       "Source Sans Pro"], 
      BaseStyle -> {"Link", FontColor -> LightDarkSwitched[
          RGBColor[0.02, 0.286, 0.651], 
          RGBColor[0.2823, 0.6666, 0.949]]}, ButtonData -> #2, ContentPadding -> 
      False], 
     MouseAppearanceTag["LinkHand"]]& )]],ExpressionUUID->
  "07705653-5cd8-407d-b5ec-29e196146adb"],
 " accepts."
}], "Item",ExpressionUUID->"df1d58ea-e180-469a-b17b-4c7a46824236"],

Cell["A PD code, DTCode, or GaussCode from the KnotTheory package.", "Item",ExpressionUUID->"1678cded-269e-4c31-a5bd-02b9aaa8db6b"],

Cell["\<\
A list of 3D points describing a space curve (e.g. sampled from a \
parametrized knot), or a list of such lists, one per component, for a \
multi-component link.\
\>", "Item",ExpressionUUID->"12326fb2-737c-4771-9122-f9a5be137205"],

Cell["\<\
A native Knoodle PD code: a list of crossing rows, each 4, 5, 6, or 7 \
integers long.\
\>", "Item",ExpressionUUID->"5a2491e0-ab99-481d-8d1a-7ada88676055"],

Cell[TextData[{
 "A ",
 Cell[BoxData[Cell["PlanarDiagramComplex",
   Background->None,ExpressionUUID->"82461a2f-4c8a-42c8-8c23-5e67c3e48323"]], 
  "InlineCode",ExpressionUUID->"09c9ce09-976f-4939-94ba-5de8ae826a98"],
 " object, as returned by ",
