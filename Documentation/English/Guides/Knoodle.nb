Notebook[{
Cell["Knoodle", "Title",ExpressionUUID->"217e52c5-ac26-4af5-a6a9-8620504467ba"],

Cell["\<\
The Knoodle paclet provides several functions complementing Mathematica's \
built-in knot theory capabilities and the KnotTheory package. \
\>", "Text",ExpressionUUID->"6389117a-c403-420f-9d47-9a3cd0a73607"],

Cell["Functions", "Section",ExpressionUUID->"3ff2690a-7328-4f83-ae7b-312436ecd8a0"],

