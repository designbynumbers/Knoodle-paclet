   Background->None,ExpressionUUID->"f7e0cea8-16f5-4b65-a85b-1bdc3b601fec"]], 
  "InlineCode",ExpressionUUID->"b86cd59e-ea0a-446a-b989-3ddb8e84dc5e"],
 " -- draw a knot or link diagram"
}], "Item",ExpressionUUID->"3ea795b9-bca8-4814-b2b3-f7c4f255b309"],

