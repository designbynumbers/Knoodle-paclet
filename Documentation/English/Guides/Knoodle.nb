Cell["About Knoodle", "GuideReferenceSection",ExpressionUUID->"a1b2c3d4-0001-4a01-9c01-0000000000a1"],

Cell["\<\
This version of the Knoodle paclet (0.9.2) packages version (1.0.6) of the \
Knoodle library. Paclet 0.9.2 is a prerelease for community feedback before \
1.0.0 is finalized.\
\>", "GuideText",ExpressionUUID->"a1b2c3d4-0001-4a01-9c01-0000000000a0"],

Cell[TextData[{
 "Knoodle is written by Henrik Schumacher and Jason Cantarella and is \
distributed under an MIT license held by Schumacher; this paclet is \
maintained by Jason Cantarella. Knoodle itself is a header-only C++ library \
with command-line tools, and can be freely incorporated into other \
programs. Source code: ",
 ButtonBox["Knoodle",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://github.com/HenrikSchumacher/Knoodle"], None}],
 " (the library and tools) and ",
 ButtonBox["Knoodle-paclet",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://github.com/designbynumbers/Knoodle-paclet"], None}],
 " (this paclet)."
}], "GuideText",ExpressionUUID->"a1b2c3d4-0001-4a01-9c01-0000000000a2"],

Cell[TextData[{
 "If you use the Knoodle paclet in academic research, please cite it as \
described in ",
 ButtonBox["CITATION.cff",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://github.com/HenrikSchumacher/Knoodle/blob/main/CITATION.cff"],
     None}],
 " on the main Knoodle repository."
}], "GuideText",ExpressionUUID->"a1b2c3d4-0001-4a01-9c01-0000000000a3"]
