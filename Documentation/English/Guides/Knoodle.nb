   ButtonData->"paclet:Knoodle/ref/KnoodleDraw"]],
  "InlineGuideFunction",ExpressionUUID->"b86cd59e-ea0a-446a-b989-3ddb8e84dc5e"],
 " \[LongDash] draw a knot or link diagram"
}], "GuideText",ExpressionUUID->"3ea795b9-bca8-4814-b2b3-f7c4f255b309"],

Cell[TextData[{
 Cell[BoxData[
